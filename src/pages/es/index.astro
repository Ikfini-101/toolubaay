---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import ClientsSection from "@components/sections/landing/ClientsSection.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";

import heroImage from "@images/peanut_farm_hero.png";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import featureImage from "@images/women_cooperative.png";
import tools from "@images/toolubaay_placeholder.png";
import { getRelativeLocaleUrl } from "astro:i18n";
import { partnersData } from "@/data_files/constants";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1531123897727-8f129e1688ce?ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout lang="es">


  <HeroSection
    title=`Empoderar a las Mujeres Rurales, <span
        class="text-yellow-500 dark:text-yellow-400">Transformar la Agricultura</span>`
    subTitle="TooluBaay estructura la cadena de valor del maní en Senegal, proporcionando herramientas digitales, formación sostenible y acceso a mercados B2B a cooperativas de mujeres rurales."
    primaryBtn="Explorar Nuestros Productos"
    primaryBtnURL={getRelativeLocaleUrl("es", "products")}
    secondaryBtn="Asociarse con Nosotros"
    secondaryBtnURL={getRelativeLocaleUrl("es", "contact")}
    withReview={false}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.8</span> / 5`
    starCount={4}
    reviews=`De más de <span class="font-bold">12.8k</span> Reseñas`
    src={heroImage}
    alt="Cooperativa de cultivo de maní en Senegal"
  />

  <ClientsSection
    title="Apoyado por Socios Visionarios"
    subTitle="Aprovechando esfuerzos colaborativos para escalar el AgriTech inclusivo."
    partners={partnersData}
  />

  <FeaturesGeneral
    title="Cultivando Impacto e Innovación"
    subTitle="En TooluBaay abordamos los desafíos de la agricultura rural en Senegal. Al combinar soluciones AgriTech con la transformación local, apoyamos a las cooperativas de mujeres, mejoramos la resiliencia de los cultivos y entregamos productos de maní de alta calidad."
    src={featureImage}
    alt="Transformación de maní por la cooperativa local de mujeres GIE"
    features={features}
  />

  <FeaturesNavs
    title=`Aprovechando <span class="text-yellow-500 dark:text-yellow-400">AgriTech</span> para una Agricultura Inteligente.`
    tabs={[
      {
        heading: "Seguimiento Meteorológico Inteligente",
        content:
          "Nuestra aplicación ofrece pronósticos agrometeorológicos localizados en lenguas locales (wolof, pulaar, mandingue), asegurando que los agricultores tomen decisiones informadas sobre cuándo sembrar, regar y cosechar.",
        svg: "tools",
        src: tools,
        alt: "Captura de pantalla de la aplicación móvil TooluBaay",
        first: true,
      },
      {
        heading: "Asistencia de Chatbot IA",
        content:
          "Un chatbot de voz interactivo (actualmente en desarrollo) diseñado para responder preguntas agrícolas en lenguas locales, haciendo que el asesoramiento agrícola experto sea accesible para todos.",
        svg: "dashboard",
        src: tools,
        alt: "Diagrama del chatbot de voz",
        second: true,
      },
      {
        heading: "Diagnóstico de Enfermedades de Cultivos",
        content:
          "Utilizando reconocimiento de imágenes por IA, los agricultores pueden tomar fotos de las hojas de los cultivos para identificar plagas y enfermedades al instante, recibiendo sugerencias inmediatas de biotratamiento.",
        svg: "house",
        src: tools,
        alt: "Tomando foto de la hoja del cultivo",
      },
    ]}
  />

  <TestimonialsSection
    title="Redefiniendo las Cadenas de Valor Rurales"
    subTitle="Empoderando a los agricultores a través de la tecnología y una remuneración justa para impulsar la soberanía alimentaria sostenible."
    testimonials={[
      {
        content:
          "TooluBaay ha cambiado por completo nuestra forma de trabajar. Con la ayuda meteorológica y los precios de compra directos, los ingresos de nuestra cooperativa han aumentado, y estamos orgullosas de ver nuestra pasta de maní en un empaque premium.",
        author: "Manio Keita",
        role: "Presidenta | GIE KamBen (Dialacoto)",
        avatarSrc:
          "https://images.unsplash.com/photo-1531123897727-8f129e1688ce?q=80&w=320&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
      },
    ]}
    statistics={[
      {
        count: "120+",
        description:
          "mujeres agricultoras empoderadas en Dialacoto, Missira y Netteboulou",
      },
      {
        count: "+25%",
        description:
          "incremento en los ingresos de las cooperativas en la Fase 1",
      },
      {
        count: "10",
        description:
          "cooperativas GIE activas estructuradas en la región de Tambacounda",
      },
      {
        count: "100%",
        description: "pasta de maní premium natural, certificada libre de aflatoxinas",
      },
    ]}
  />

  <FAQ title="Preguntas<br />frecuentes" faqs={faqs} />

  <HeroSectionAlt
    title="Apoye la Soberanía y el Impacto"
    subTitle="Únase a nosotros para expandir la cadena de valor de transformación de maní inclusiva en todo Senegal."
    url={getRelativeLocaleUrl("es", "contact")}
  />
</MainLayout>
