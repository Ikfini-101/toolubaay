---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import PhotoCarousel from "@components/sections/landing/PhotoCarousel.astro";
import CEOSection from "@components/sections/landing/CEOSection.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";

import heroImage from "@images/peanut_farm_hero.png";
import faqs from "@data/fr/faqs.json";
import features from "@data/fr/features.json";
import featureImage from "@images/women_cooperative.png";
import tools from "@images/toolubaay_placeholder.png";
import { getRelativeLocaleUrl } from "astro:i18n";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1531123897727-8f129e1688ce?ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout lang="fr">


  <HeroSection
    title=`Valoriser les Femmes Rurales, <span class="text-yellow-500 dark:text-yellow-400">Transformer l'Agriculture</span>`
    subTitle="TooluBaay structure la filière arachide au Sénégal, fournissant aux coopératives de femmes rurales des outils numériques, des formations durables et un accès au marché B2B."
    primaryBtn="Découvrir nos produits"
    primaryBtnURL={getRelativeLocaleUrl("fr", "products")}
    secondaryBtn="Devenir Partenaire"
    secondaryBtnURL={getRelativeLocaleUrl("fr", "contact")}
    withReview={false}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.8</span> / 5`
    starCount={4}
    reviews=`À partir de plus de <span class="font-bold">12,8k</span> avis`
    src={heroImage}
    alt="Coopérative de culture d'arachide au Sénégal"
  />

  <PhotoCarousel
    title="La Vie de nos Coopératives en Images"
    subTitle="Découvrez en images le quotidien de nos productrices et de nos GIE partenaires."
  />

  <CEOSection />

  <FeaturesGeneral
    title="Cultiver l'Impact & l'Innovation"
    subTitle="Chez TooluBaay, nous relevons les défis uniques de l'agriculture familiale au Sénégal. En combinant solutions AgriTech et transformation locale, nous renforçons les GIE de femmes, améliorons la résilience des cultures et livrons une pâte d'arachide premium de qualité supérieure."
    src={featureImage}
    alt="Transformation de la pâte d'arachide par des femmes locales"
    features={features}
  />

  <FeaturesNavs
    title=`L'intelligence <span class="text-yellow-500 dark:text-yellow-400">AgriTech</span> au service des champs.`
    tabs={[
      {
        heading: "Suivi Agroclimatique",
        content:
          "Notre application mobile fournit des prévisions météo agricoles localisées et vocales dans les langues locales (wolof, pulaar, mandingue), aidant les paysans à planifier au mieux leurs récoltes.",
        svg: "tools",
        src: tools,
        alt: "Application mobile TooluBaay",
        first: true,
      },
      {
        heading: "Chatbot IA Vocal",
        content:
          "Un conseiller agricole virtuel interactif (en cours de développement) conçu pour répondre en langues locales aux questions des producteurs pour démocratiser l'accès au conseil.",
        svg: "dashboard",
        src: tools,
        alt: "Schéma du conseiller IA vocal",
        second: true,
      },
      {
        heading: "Diagnostic de Maladies par Photo",
        content:
          "Grâce à la reconnaissance d'images par IA, le producteur prend une photo d'une feuille malade et reçoit instantanément un diagnostic et des suggestions de traitement bio.",
        svg: "house",
        src: tools,
        alt: "Prise de photo d'une feuille malade",
      },
    ]}
  />

  <TestimonialsSection
    title="Restructurer les Chaînes de Valeur Rurales"
    subTitle="Soutenir la souveraineté alimentaire nationale par la juste rémunération des productrices et l'innovation."
    testimonials={[
      {
        content:
          "TooluBaay a complètement changé notre quotidien. Grâce au suivi météo et au prix d'achat garanti, les revenus de notre coopérative ont augmenté, et nous sommes fières de voir notre pâte d'arachide vendue dans des pots premium.",
        author: "Manio Keita",
        role: "Présidente | GIE KamBen (Dialacoto)",
        avatarSrc:
          "https://images.unsplash.com/photo-1531123897727-8f129e1688ce?q=80&w=320&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
      },
    ]}
    statistics={[
      {
        count: "120+",
        description:
          "femmes rurales accompagnées à Dialacoto, Missira et Netteboulou",
      },
      {
        count: "+25%",
        description:
          "de hausse de revenus pour les coopératives partenaires en Phase 1",
      },
      {
        count: "10",
        description:
          "GIE de femmes structurés dans la région de Tambacounda",
      },
      {
        count: "100%",
        description: "naturel, garanti sans aflatoxine pour un standard B2B premium",
      },
    ]}
  />

  <FAQ title="Questions<br />fréquemment posées" faqs={faqs} />

  <HeroSectionAlt
    title="Soutenir l'Autonomie & l'Impact"
    subTitle="Rejoignez-nous pour étendre la chaîne de valeur inclusive de transformation d'arachide au Sénégal."
    url={getRelativeLocaleUrl("fr", "contact")}
  />
</MainLayout>
