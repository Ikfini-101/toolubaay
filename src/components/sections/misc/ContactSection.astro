---
// Import the necessary dependencies.
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import TextInput from "@components/ui/forms/input/TextInput.astro";
import EmailContactInput from "@components/ui/forms/input/EmailContactInput.astro";
import PhoneInput from "@components/ui/forms/input/PhoneInput.astro";
import TextAreaInput from "@components/ui/forms/input/TextAreaInput.astro";
import Icon from "@components/ui/icons/Icon.astro";
import ContactForm from "@components/sections/misc/ContactForm.astro";

// Define the variables that will be used in this component
const title: string = "Contact us";
const subTitle: string =
  "Have questions about our peanut paste, our AgriTech approach, or want to discuss a B2B partnership? Reach out, and let's craft the perfect solution together.";
const formTitle: string = "Fill in the form below";
const formSubTitle: string = "We'll get back to you in 1-2 business days.";
---

<!-- Contact Us -->
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        <!-- Form for user input with various input fields.-->
        <!-- Each field utilizes a different input component for the specific type of input (text, email, phone, and textarea)-->
        <ContactForm lang="en" />
      </div>

      <!--ContactIconBlocks are used to display different methods of contacting, including visiting office, email, browsing knowledgebase, and FAQ.-->
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Knowledgebase"
          content="Browse through all of our knowledgebase articles."
          isLinkVisible={true}
          linkTitle="Visit guides & tutorials"
          linkURL="#"
          isArrowVisible={true}
          ><Icon name="question" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="FAQ"
          content="Explore our FAQ for quick, clear answers to common queries."
          isLinkVisible={true}
          linkTitle="Visit FAQ"
          linkURL="#"
          isArrowVisible={true}
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Visit our office"
          content="TooluBaay"
          isAddressVisible={true}
          addressContent="Tambacounda, Sénégal"
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Contact us by email"
          content="Prefer the written word? Drop us an email at"
          isLinkVisible={true}
          linkTitle="info.toolubaay@gmail.com"
          linkURL="mailto:info.toolubaay@gmail.com"
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      const htmlElement = document.documentElement;
      const lang = htmlElement.getAttribute("lang") || "en";
      
      const strings = {
        en: {
          sending: "Sending...",
          success: "Message sent successfully!",
          error: "Error sending. Opening your email client...",
          defaultBtn: "Send Message"
        },
        es: {
          sending: "Enviando...",
          success: "¡Mensaje enviado con éxito!",
          error: "Error de envío. Abriendo su cliente de correo...",
          defaultBtn: "Enviar mensaje"
        }
      };
      
      const t = strings[lang as keyof typeof strings] || strings.en;
      
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = t.sending;
      }

      const formData = new FormData(form);
      const data: Record<string, string> = {};
      formData.forEach((value, key) => {
        data[key] = value.toString();
      });

      const web3FormsKey = "a8b7c7b8-8097-4d94-a957-3f920255a539"; // Testing key

      const payload = {
        access_key: web3FormsKey,
        name: `${data["hs-firstname-contacts"] || ""} ${data["hs-lastname-contacts"] || ""}`.trim(),
        email: data["hs-email-contacts"] || "",
        phone: data["hs-phone-number"] || "",
        message: data["hs-about-contacts"] || "",
        subject: "Nouveau message de contact - TooluBaay",
        ccemail: "cbllniv15@gmail.com"
      };

      let success = false;
      
      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify(payload)
        });

        const result = await response.json();
        if (response.status === 200 && result.success) {
          success = true;
        }
      } catch (err) {
        console.error("Error sending via API:", err);
      }

      if (success) {
        showToast(t.success, "success");
        form.reset();
      } else {
        showToast(t.error, "warning");
        const mailtoUrl = `mailto:info.toolubaay@gmail.com?cc=cbllniv15@gmail.com&subject=Contact%20TooluBaay&body=First%20Name%20:%20${encodeURIComponent(data["hs-firstname-contacts"] || "")}%0ALast%20Name%20:%20${encodeURIComponent(data["hs-lastname-contacts"] || "")}%0APhone%20:%20${encodeURIComponent(data["hs-phone-number"] || "")}%0A%0AMessage%20:%20${encodeURIComponent(data["hs-about-contacts"] || "")}`;
        window.location.href = mailtoUrl;
      }

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = t.defaultBtn;
      }
    });
  }

  function showToast(message: string, type: "success" | "error" | "warning") {
    const toast = document.createElement("div");
    toast.className = `fixed bottom-4 right-4 z-50 flex items-center gap-3 rounded-2xl border px-5 py-4 shadow-2xl backdrop-blur-md transition-all duration-500 translate-y-10 opacity-0 ${
      type === "success" 
        ? "border-emerald-500/30 bg-emerald-950/80 text-emerald-200" 
        : "border-amber-500/30 bg-amber-950/80 text-amber-200"
    }`;
    
    toast.innerHTML = `
      <span class="text-lg">${type === 'success' ? '✓' : '⚠'}</span>
      <p class="text-sm font-semibold">${message}</p>
    `;
    
    document.body.appendChild(toast);
    
    setTimeout(() => {
      toast.classList.remove("translate-y-10", "opacity-0");
    }, 10);
    
    setTimeout(() => {
      toast.classList.add("translate-y-10", "opacity-0");
      setTimeout(() => {
        toast.remove();
      }, 500);
    }, 4000);
  }
</script>
