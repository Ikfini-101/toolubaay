---
import { Image } from "astro:assets";
import ceoImage from "@images/carousel/photo_du_ceo_lors_d_une_renconytre_assis_a_table.avif";

const locale = Astro.currentLocale;

// Internationalized content strings
const content = {
  fr: {
    title: "Le Mot du Fondateur & CEO",
    subTitle: "Engagement & Impact Communautaire",
    name: "Sene Philippe Auguste Moundor",
    role: "CEO & Fondateur, TooluBaay",
    paragraphs: [
      "Engagé pour l'autonomisation durable des communautés rurales, Philippe Moundor Sene a fondé TooluBaay avec une vision claire : structurer et professionnaliser la filière arachide sénégalaise en valorisant le travail des femmes ruraux.",
      "En organisant les productrices en GIE équipés et formés, TooluBaay garantit une hausse de revenus de plus de 25% et une traçabilité totale. Aligné sur les objectifs du Plan National de Transformation Agricole (Vision Sénégal 2050), son engagement allie innovation AgriTech et commerce équitable pour bâtir un modèle résilient de souveraineté alimentaire au Sénégal."
    ],
    engagementsTitle: "Nos Engagements Structurants :",
    engagements: [
      "Inclusion socio-économique active de 120+ femmes transformatrices en Phase 1.",
      "Achat équitable garanti à 800 FCFA/kg (soit +14% à +33% de hausse directe).",
      "Déploiement d'une application de suivi agroclimatique en langues locales.",
      "Valorisation et transformation locale (standard B2B 100% naturel sans aflatoxine)."
    ]
  },
  en: {
    title: "A Message from the Founder & CEO",
    subTitle: "Commitment & Community Impact",
    name: "Sene Philippe Auguste Moundor",
    role: "CEO & Founder, TooluBaay",
    paragraphs: [
      "Committed to the sustainable empowerment of rural communities, Philippe Moundor Sene founded TooluBaay with a clear vision: to structure and professionalize the Senegalese groundnut value chain by showcasing women's labor.",
      "By organizing female producers into equipped and trained cooperatives (GIEs), TooluBaay guarantees an income increase of over 25% and complete traceability. Aligned with the National Agricultural Transformation Plan, his commitment merges AgriTech innovation with fair trade to build a resilient model for food sovereignty in Senegal."
    ],
    engagementsTitle: "Key Structured Commitments:",
    engagements: [
      "Active socio-economic empowerment of 120+ rural women in Phase 1.",
      "Guaranteed fair purchase price at 800 FCFA/kg (+14% to +33% increase).",
      "Launch of a vocal agrometeorological mobile application in local languages.",
      "Local transformation and value creation (100% natural, aflatoxin-free B2B standards)."
    ]
  },
  es: {
    title: "Mensaje del Fundador y CEO",
    subTitle: "Compromiso e Impacto Comunitario",
    name: "Sene Philippe Auguste Moundor",
    role: "CEO y Fundador, TooluBaay",
    paragraphs: [
      "Comprometido con el empoderamiento sostenible de las comunidades rurales, Philippe Moundor Sene fundó TooluBaay con una visión clara: estructurar y profesionalizar la cadena de valor del cacahuete en Senegal, valorando el trabajo de las mujeres.",
      "Al organizar a las productoras en cooperativas (GIE) equipadas y capacitadas, TooluBaay garantiza un aumento de ingresos superior al 25% y una trazabilidad total. En consonancia con el Plan Nacional de Transformación Agrícola, su compromiso combina la innovación AgriTech con el comercio justo para construir un modelo de soberanía alimentaria de alta calidad en Senegal."
    ],
    engagementsTitle: "Compromisos Estructurantes Clave:",
    engagements: [
      "Empoderamiento socioeconómico activo de más de 120 mujeres en la Fase 1.",
      "Precio garantizado de compra justa a 800 FCFA/kg (aumento directo del +14% al +33%).",
      "Lanzamiento de una aplicación móvil agroclimática vocal en lenguas locales.",
      "Procesamiento local con altos estándares B2B (100% natural y libre de aflatoxinas)."
    ]
  }
};

const activeStrings = content[(locale || "fr") as keyof typeof content] || content.fr;
---

<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
  <div class="relative rounded-[2rem] border border-yellow-100/40 bg-yellow-50/20 p-8 dark:border-neutral-700/40 dark:bg-neutral-800/20 backdrop-blur-xs shadow-xl">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <!-- Portrait Column -->
      <div class="relative mx-auto max-w-md lg:mx-0">
        <div class="relative overflow-hidden rounded-3xl border border-yellow-100/30 shadow-2xl">
          <Image
            src={ceoImage}
            alt={activeStrings.name}
            class="w-full h-[400px] object-cover transition-transform duration-500 hover:scale-102"
          />
          <div class="absolute bottom-0 inset-x-0 bg-linear-to-t from-black/80 via-black/40 to-transparent p-6 text-white">
            <h3 class="text-xl font-bold">{activeStrings.name}</h3>
            <p class="text-sm text-yellow-400 dark:text-yellow-300 font-medium">{activeStrings.role}</p>
          </div>
        </div>
      </div>

      <!-- Description and Commitments Column -->
      <div class="flex flex-col justify-center space-y-6">
        <div class="space-y-2">
          <span class="text-xs font-bold uppercase tracking-wider text-orange-600 dark:text-orange-400">
            {activeStrings.subTitle}
          </span>
          <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">
            {activeStrings.title}
          </h2>
        </div>

        <div class="space-y-4 text-neutral-600 dark:text-neutral-400">
          {
            activeStrings.paragraphs.map((p: string) => (
              <p class="text-pretty leading-relaxed text-sm md:text-base">{p}</p>
            ))
          }
        </div>

        <div class="pt-4 border-t border-neutral-200/20">
          <h4 class="font-bold text-neutral-800 dark:text-neutral-200 mb-3 text-sm md:text-base">
            {activeStrings.engagementsTitle}
          </h4>
          <ul class="space-y-2 text-sm text-neutral-600 dark:text-neutral-400">
            {
              activeStrings.engagements.map((item: string) => (
                <li class="flex items-start gap-x-2">
                  <svg class="h-5 w-5 shrink-0 text-orange-600 dark:text-orange-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
