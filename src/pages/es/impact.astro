---
import MainLayout from "@/layouts/MainLayout.astro";
import { Image } from "astro:assets";
import womenCoop from "@images/women_cooperative.png";
import { SITE } from "@data/constants";

const pageTitle = `Nuestro Impacto | ${SITE.title}`;
const metaDescription =
  "Descubra cómo TooluBaay empodera a las cooperativas de mujeres y jóvenes en el medio rural en Senegal, garantiza ingresos equitables e impulsa una transformación agrícola sostenible.";
const ogTitle = "Impacto y Sostenibilidad | TooluBaay";

// GIE Cooperatives data
const cooperatives = [
  { code: "TB-TBA-001", name: "GIE Kamben Transformation", location: "Dialacoto", leader: "Manio Keita", role: "GIE Piloto Activo" },
  { code: "TB-TBA-002", name: "GIE Fokaben", location: "Darsalam", leader: "Koule Makalou", role: "GIE Socio" },
  { code: "TB-TBA-003", name: "GIE GPF Leral", location: "Diagle-Sine", leader: "Waatew Diouf", role: "GIE Socio" },
  { code: "TB-TBA-004", name: "GIE Fandema Kaffo", location: "Bantantinty", leader: "Fanta Toure", role: "GIE Socio" },
  { code: "TB-TBA-005", name: "GIE And Jubbo", location: "Sinthiou Malem", leader: "Mamadou Aliou Ba", role: "GIE Socio" },
  { code: "TB-TBA-006", name: "GIE Takku Ligguey", location: "Keur Ousmane", leader: "Ndeye Fatou Ndiaye", role: "GIE Socio" },
  { code: "TB-TBA-007", name: "GIE Berete", location: "Darou Ndibélane", leader: "Fatoumata Bintou Diallo", role: "GIE Socio" },
  { code: "TB-TBA-008", name: "GIE Deggo", location: "Darou Ndibélane", leader: "Alsane Diop", role: "GIE Socio" },
  { code: "TB-TBA-009", name: "GIE 4R", location: "Sinthiou Malem", leader: "Ndiémé Camara", role: "GIE Socio" },
  { code: "TB-TBA-010", name: "GIE Alanso 2", location: "Bantantity", leader: "Coumba Waly", role: "GIE Socio" }
];

// SDG goals data
const sdgs = [
  {
    number: "1",
    title: "Fin de la Pobreza",
    description: "Al comprar la pasta de maní a un precio de compra garantizado y equitativo (superior a las tarifas del mercado local), aseguramos ingresos estables y mayores para las familias en el medio rural."
  },
  {
    number: "5",
    title: "Igualdad de Género",
    description: "Trabajamos directamente con grupos de interés económico (GIE) liderados por mujeres y jóvenes, proporcionando herramientas, formalización y formación para fomentar la independencia financiera."
  },
  {
    number: "8",
    title: "Trabajo Decente",
    description: "Creación de más de 120 empleos directos para mujeres y jóvenes en la Fase 1, profesionalizando el oficio de transformación de maní bajo altos estándares de seguridad, higiene y HACCP."
  },
  {
    number: "13",
    title: "Acción por el Clima",
    description: "Equipamos a las agricultoras con asesoramiento agroclimático y tecnología móvil para construir resiliencia frente a los patrones climáticos erráticos en Senegal."
  }
];

// Vision Senegal 2050 data
const vision2050 = [
  {
    number: "1",
    title: "Soberanía Alimentaria",
    description: "Reducción de la dependencia de las importaciones mediante el aumento de la producción local de pasta de maní de calidad premium."
  },
  {
    number: "2",
    title: "Industrialización",
    description: "Modernización del procesamiento artesanal con equipos semiindustriales que cumplen con los estándares internacionales."
  },
  {
    number: "3",
    title: "Inclusión de Jóvenes y Mujeres",
    description: "Integración activa y empoderamiento socioeconómico de mujeres y jóvenes rurales a través de las cooperativas GIE."
  },
  {
    number: "4",
    title: "Empoderamiento Económico",
    description: "Garantizar ingresos estables y basados en contratos para los miembros de las cooperativas mediante precios justos."
  },
  {
    number: "5",
    title: "Agricultura Sostenible",
    description: "Despliegue de soluciones AgriTech para mejorar la resiliencia de los cultivos frente a los desafíos agroclimáticos."
  },
  {
    number: "6",
    title: "Creación de Valor Local",
    description: "Procesamiento de materias primas localmente para maximizar los beneficios económicos directos en las comunidades rurales."
  }
];
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  lang="es"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/es/impact",
    url: "https://toolubaay.sn/es/impact",
    name: "Nuestro Impacto | TooluBaay",
    description: "Descubra el impacto socioeconómico y ambiental del modelo cooperativo de TooluBaay en Senegal.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn/es",
      name: "TooluBaay",
      description: "Cooperativa de AgriTech y transformación de maní de mujeres y jóvenes en Senegal."
    },
    inLanguage: "es"
  }}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800 dark:bg-emerald-950 dark:text-emerald-200">
            Nuestra Misión e Impacto
          </span>
          <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-4xl md:text-5xl">
            Empoderar a las Mujeres y Jóvenes, <span class="text-emerald-600 dark:text-emerald-500">Transformar las Comunidades</span>
          </h1>
          <p class="mt-6 text-lg text-neutral-600 dark:text-neutral-400">
            TooluBaay opera un modelo híbrido inclusivo que fusiona la innovación AgriTech con la agrotransformación local. Al apoyar a un red estructurada de GIE (Groupements d'Intérêt Économique) gérés por mujeres y jóvenes en nuestros polos agrícolas, cerramos la brecha entre los pequeños productores y los mercados de calidad premium.
          </p>
        </div>
        <div class="relative">
          <Image
            src={womenCoop}
            alt="Miembros de la cooperativa de mujeres clasificando y transformando maní"
            class="w-full rounded-2xl object-cover shadow-xl dark:shadow-neutral-950"
          />
          <div class="absolute -bottom-6 -start-6 h-40 w-40 rounded-2xl bg-amber-500/10 -z-10"></div>
          <div class="absolute -top-6 -end-6 h-40 w-40 rounded-2xl bg-emerald-500/10 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Impact Stats -->
  <section class="bg-white py-12 dark:bg-neutral-950">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-12">
        <div class="text-center">
          <p class="text-4xl font-extrabold text-amber-500 md:text-5xl">120+</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Beneficiarias Directas</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Mujeres y jóvenes en la Fase 1</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-extrabold text-emerald-600 md:text-5xl">+20 GIE</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Cooperativas Activas</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Redes GIE organizadas localmente</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-extrabold text-amber-500 md:text-4xl">Equitativo</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Precio Garantizado</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Pagados directamente a las cooperativas</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-extrabold text-emerald-600 md:text-5xl">10%</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Reinversión de Beneficios</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Dedicado a la capacitación empresarial</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SDG Section -->
  <section class="bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Alineación con los Objetivos de Desarrollo Sostenible</h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">Nuestro modelo de negocio está diseñado en torno al impacto social, apuntando a los ODS clave de las Naciones Unidas para impulsar un desarrollo rural duradero en Senegal.</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {sdgs.map((sdg) => (
          <div class="flex flex-col rounded-xl bg-white p-6 shadow-sm dark:bg-neutral-950 dark:border-neutral-800 border border-neutral-200">
            <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-100 text-lg font-bold text-emerald-800 dark:bg-emerald-950 dark:text-emerald-200">
              {sdg.number}
            </span>
            <h3 class="mt-5 font-bold text-neutral-800 dark:text-neutral-200 text-lg">ODS {sdg.number}: {sdg.title}</h3>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed flex-grow">
              {sdg.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Vision Senegal 2050 Section -->
  <section class="bg-white py-16 dark:bg-neutral-950 lg:py-24 border-t border-neutral-200/20">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Alineación con la Visión Senegal 2050</h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">TooluBaay se alinea plenamente con las directrices estratégicas nacionales de Senegal para fomentar una economía rural fuerte, soberana e inclusiva.</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {vision2050.map((item) => (
          <div class="flex flex-col rounded-xl bg-neutral-50 p-6 shadow-xs dark:bg-neutral-900 dark:border-neutral-800 border border-neutral-200">
            <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-amber-100 text-lg font-bold text-amber-800 dark:bg-amber-950 dark:text-amber-200">
              {item.number}
            </span>
            <h3 class="mt-5 font-bold text-neutral-800 dark:text-neutral-200 text-lg">{item.title}</h3>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed flex-grow">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GIE Partners Section -->
  <section class="bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24 border-t border-neutral-200/20">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Nuestra Red de Cooperativas GIE de Mujeres y Jóvenes</h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">
          Nos asociamos con una red de cooperativas locales en nuestros polos agrícolas, estandarizando los equipos de producción y ofreciendo formación para garantizar altos estándares de higiene, seguridad y conformidad con las normas HACCP.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cooperatives.map((coop) => (
          <div class="group flex flex-col justify-between rounded-xl border border-neutral-200 bg-white p-6 transition-all duration-300 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-950">
            <div>
              <div class="flex items-center justify-between">
                <span class="text-xs font-mono font-bold text-neutral-500 dark:text-neutral-400">{coop.code}</span>
                <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-950 dark:text-amber-200">
                  {coop.role}
                </span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-neutral-800 group-hover:text-emerald-600 dark:text-neutral-200 dark:group-hover:text-emerald-500 transition-colors">
                {coop.name}
              </h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
                <span class="font-semibold text-neutral-700 dark:text-neutral-300">Ubicación:</span> {coop.location}
              </p>
              <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                <span class="font-semibold text-neutral-700 dark:text-neutral-300">Líder:</span> {coop.leader}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
