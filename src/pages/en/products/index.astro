---
// Importing necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import CardSmall from "@components/ui/cards/CardSmall.astro";
import CardWide from "@components/ui/cards/CardWide.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import FloatingPeanuts from "@components/ui/decorations/FloatingPeanuts.astro";
// Importing necessary functions from Astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";

// Fetching all the product related content and sorting it by main.id
const product: CollectionEntry<"products">[] = (
  await getCollection("products", ({ id }) => {
    return id.startsWith("en/");
  })
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id
);

// Define variables for page content
const title: string = "Premium Peanut Paste";
const subTitle: string =
  "Explore our range of 100% natural, premium peanut paste. Handcrafted by local women cooperatives in Tambacounda, Senegal. Guaranteed aflatoxin-free, rich in nutrition and social impact.";

const pageTitle: string = `Products | ${SITE.title}`;
const metaDescription =
  "Discover our 100% natural, premium peanut paste formats, handcrafted by Senegalese women cooperatives.";
const ogTitle = "Premium Peanut Paste | TooluBaay";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/en/products",
    url: "https://toolubaay.sn/en/products",
    name: "Premium Peanut Paste | TooluBaay",
    description:
      "Discover our 100% natural, premium peanut paste formats, handcrafted by Senegalese women cooperatives.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn/en",
      name: "TooluBaay",
      description:
        "TooluBaay structures the peanut value chain in Senegal, providing rural women cooperatives with B2B market access.",
    },
    inLanguage: "en-US",
  }}
>
  <div class="relative w-full overflow-hidden">
    <FloatingPeanuts />
    <div
      class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full relative z-10"
    >
    <div class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12">
      <div class="flex items-center gap-12">
        <h1
          class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
        >
          {title}
        </h1>
        {
          subTitle && (
            <p class="hidden max-w-(--breakpoint-sm) text-pretty text-neutral-600 md:block dark:text-neutral-400">
              {subTitle}
            </p>
          )
        }
    </div>
    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} />;
          } else {
            return <CardWide product={product} />;
          }
        })
      }
    </section>
    </div>
  </div>
  {/* Features statistics section */}
  <FeaturesStatsAlt
    title="Why Choose TooluBaay?"
    subTitle="By choosing our products, you directly support Senegalese rural women. We guarantee high-grade raw peanut selection, strict quality control (zero aflatoxin, zero additives), and a transparent, traceable supply chain."
    benefits={[
      "100% natural peanut paste with premium texture and ocre color.",
      "Fair price purchasing directly empowering rural women GIEs.",
      "Aflatoxin-free certified for highest food safety compliance.",
    ]}
  />
</MainLayout>
