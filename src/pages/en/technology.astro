---
import MainLayout from "@/layouts/MainLayout.astro";
import { SITE } from "@data/constants";

const pageTitle = `Technology | ${SITE.title}`;
const metaDescription =
  "Discover TooluBaay's technology: multilingual agro-weather app, QR traceability codes, mobile money payments and digital innovations empowering women and youth in rural Senegal.";
const ogTitle = "Technology & Innovation | TooluBaay";

const techPillars = [
  {
    icon: "📱",
    title: "Multilingual Agro-Weather App",
    description:
      "Mobile application available in Wolof, Pulaar and Mandinka. Precise weather forecasts, tailored agronomic advice and climate risk alerts for partner GIE cooperatives.",
    features: [
      "Localized weather forecasts (planting, harvesting, irrigation)",
      "Real-time drought and excess rainfall alerts",
      "Groundnut variety advice & agricultural calendar",
      "Voice interface adapted for women and youth with low literacy",
    ],
    color: "emerald",
  },
  {
    icon: "🔍",
    title: "QR Traceability Code",
    description:
      "Every jar of TooluBaay peanut paste carries a unique QR code. Buyers can scan it to access the complete batch history: producing GIE cooperative, harvest date, and quality controls.",
    features: [
      "Unique identification per batch produced",
      "Direct link to producing GIE cooperative profile",
      "Quality data (aflatoxin level, moisture content)",
      "Builds trust with premium buyers and export markets",
    ],
    color: "amber",
  },
  {
    icon: "💸",
    title: "Mobile Money & Digital Payments",
    description:
      "Integration of mobile money (Orange Money, Wave, Free Money) to secure payments between TooluBaay and GIE cooperatives. Full financial traceability and enhanced trust.",
    features: [
      "GIE payments secured within 48h via mobile money",
      "Real-time order and payment tracking",
      "Reduced cash risk in rural areas",
      "Transaction history accessible to GIEs",
    ],
    color: "blue",
  },
  {
    icon: "🎓",
    title: "Digital Training Module",
    description:
      "Library of short videos integrated into the app: hygiene best practices, grinding techniques, quality management, and TooluBaay packaging mastery.",
    features: [
      "Short videos in local languages (Wolof, Pulaar)",
      "Hygiene, food safety, and HACCP compliance protocols",
      "Equipment operation tutorials",
      "Continuously updated based on field feedback",
    ],
    color: "purple",
  },
];

const impactMetrics = [
  { value: "3", label: "Local Languages", sub: "Wolof, Pulaar, Mandinka" },
  { value: ">60%", label: "Mobile Money Penetration", sub: "Across Senegal" },
  { value: "7", label: "Quality Control Steps", sub: "Digitally traced" },
  { value: "QR", label: "Unique Code / Batch", sub: "On every peanut paste jar" },
];
---

<MainLayout
  title={pageTitle}
  lang="en"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/en/technology",
    url: "https://toolubaay.sn/en/technology",
    name: "Technology & Innovation | TooluBaay",
    description: "Multilingual agro-weather app, QR traceability codes and mobile money at the service of rural women and youth GIE cooperatives.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn",
      name: "TooluBaay",
      description: "AgriTech and peanut paste transformation cooperative by rural women and youth in Senegal.",
    },
    inLanguage: "en",
  }}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-neutral-900 via-emerald-950 to-neutral-900 py-20 lg:py-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 h-64 w-64 rounded-full bg-emerald-400 blur-3xl"></div>
      <div class="absolute bottom-10 right-10 h-64 w-64 rounded-full bg-amber-400 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-flex items-center gap-2 rounded-full bg-emerald-900/60 border border-emerald-700/50 px-4 py-1.5 text-sm font-medium text-emerald-300">
          🚀 AgriTech Innovation
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Technology in Service
          <span class="text-emerald-400"> of the Field</span>
        </h1>
        <p class="mt-6 text-lg text-neutral-300 leading-relaxed">
          TooluBaay develops digital tools built for the realities of women and youth in rural Senegal. Multilingual mobile app, QR traceability codes and mobile money payments — technology as a lever for empowerment.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/traceability"
            class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-6 py-3 font-semibold text-white transition hover:bg-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-neutral-900"
          >
            🔍 Test Traceability
          </a>
          <a
            href="/en/contact"
            class="inline-flex items-center gap-2 rounded-xl border border-neutral-600 bg-neutral-800/60 px-6 py-3 font-semibold text-white transition hover:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:ring-offset-2 focus:ring-offset-neutral-900"
          >
            💬 Become a Tech Partner
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Metrics -->
  <section class="bg-white dark:bg-neutral-950 py-12 border-b border-neutral-200 dark:border-neutral-800">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {impactMetrics.map((m) => (
          <div class="text-center">
            <p class="text-4xl font-black text-emerald-600 dark:text-emerald-400">{m.value}</p>
            <p class="mt-1 text-sm font-semibold text-neutral-800 dark:text-neutral-200">{m.label}</p>
            <p class="text-xs text-neutral-500 dark:text-neutral-400">{m.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology Pillars -->
  <section class="bg-neutral-50 dark:bg-neutral-900 py-16 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-100 sm:text-4xl">
          The 4 Technology Pillars
        </h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">
          An integrated digital ecosystem that improves every link in the groundnut value chain.
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2">
        {techPillars.map((pillar) => (
          <div class="rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm transition hover:shadow-md dark:border-neutral-800 dark:bg-neutral-950">
            <div class="flex items-start gap-4">
              <span class="text-4xl">{pillar.icon}</span>
              <div>
                <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">{pillar.title}</h3>
                <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">{pillar.description}</p>
              </div>
            </div>
            <ul class="mt-6 space-y-2">
              {pillar.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-neutral-700 dark:text-neutral-300">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- App Impact Section -->
  <section class="bg-white dark:bg-neutral-950 py-16 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
        <div>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800 dark:bg-amber-950 dark:text-amber-200">
            Structural Competitive Advantage
          </span>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-100 sm:text-4xl">
            The TooluBaay App: A Profitability Multiplier
          </h2>
          <p class="mt-4 text-neutral-600 dark:text-neutral-400 leading-relaxed">
            The TooluBaay agro-weather app is a unique structural competitive advantage in the Senegalese groundnut sector. It creates a direct virtuous cycle:
          </p>
          <div class="mt-6 space-y-4">
            {[
              { step: "1", title: "Better-Informed GIEs", desc: "Precise weather forecasts and agronomic advice reduce pre-harvest losses." },
              { step: "2", title: "Higher Paste Quality", desc: "Better-managed groundnuts = fewer quality rejections at the packaging center." },
              { step: "3", title: "Stable GIE Revenues", desc: "Fewer rejections = regular guaranteed payments for women and youth in GIE cooperatives." },
              { step: "4", title: "Reliable Supply", desc: "TooluBaay consistently meets premium quality and export commitments." },
            ].map((item) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 flex items-center justify-center h-8 w-8 rounded-full bg-emerald-600 text-white text-sm font-bold">
                  {item.step}
                </div>
                <div>
                  <h4 class="font-semibold text-neutral-800 dark:text-neutral-100">{item.title}</h4>
                  <p class="text-sm text-neutral-600 dark:text-neutral-400">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="mt-10 lg:mt-0">
          <div class="rounded-2xl bg-gradient-to-br from-emerald-600 to-emerald-800 p-8 text-white shadow-xl">
            <h3 class="text-xl font-bold mb-6">Quantified Operational Impact</h3>
            <div class="space-y-4">
              {[
                { label: "Post-harvest loss reduction", value: "−15 to −25%" },
                { label: "Lots rejected for quality", value: "< 5% (target)" },
                { label: "GIE payment delay", value: "48h via mobile money" },
                { label: "GIEs trained digitally", value: "10 → 500 (Phase 5)" },
                { label: "Local languages supported", value: "3 (Wolof, Pulaar, Mandinka)" },
              ].map((item) => (
                <div class="flex items-center justify-between border-b border-emerald-700/50 pb-3">
                  <span class="text-sm text-emerald-100">{item.label}</span>
                  <span class="font-bold text-white">{item.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-emerald-700 dark:bg-emerald-800 py-16">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white">
        Got an AgriTech Project for Africa?
      </h2>
      <p class="mt-4 text-emerald-100 max-w-2xl mx-auto">
        TooluBaay is open to technology partnerships. Developers, funders, incubators — contact us to co-build solutions adapted to the field.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={`https://wa.me/221774745011?text=${encodeURIComponent("Hello, I am interested in a technology partnership with TooluBaay.")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 font-semibold text-emerald-700 transition hover:bg-emerald-50"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Contact on WhatsApp
        </a>
        <a
          href="mailto:info.toolubaay@gmail.com?subject=Tech Partnership TooluBaay"
          class="inline-flex items-center gap-2 rounded-xl border border-white/30 bg-emerald-600/50 px-6 py-3 font-semibold text-white transition hover:bg-emerald-600"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          Write Us an Email
        </a>
      </div>
    </div>
  </section>
</MainLayout>
