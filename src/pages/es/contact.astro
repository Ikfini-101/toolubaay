---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { SITE } from "@data/constants";

const pageTitle: string = `Contacto | ${SITE.title}`;
const metaDescription =
  "¿Tiene preguntas o quiere colaborar? Póngase en contacto con nosotros y colaboremos juntos.";
const ogTitle = "Contacto | TooluBaay";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  lang="es"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://screwfast.uk/es/contact",
    url: "https://screwfast.uk/es/contact",
    name: "Contacto | TooluBaay",
    description:
      "¿Tiene preguntas o quiere colaborar? Póngase en contacto con nosotros y colaboremos juntos.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://screwfast.uk/es",
      name: "TooluBaay",
      description:
        "TooluBaay ofrece herramientas digitales y transformación de maní premium en Senegal.",
    },
    inLanguage: "es",
  }}
>
  <ContactSection />
</MainLayout>
