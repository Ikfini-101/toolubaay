---
import MainLayout from "@/layouts/MainLayout.astro";
import { SITE } from "@data/constants";

const pageTitle = `Product Traceability | ${SITE.title}`;
const metaDescription =
  "Track the journey of your TooluBaay peanut paste. Enter your lot code to discover the GIE cooperative origin, harvest details, and quality metrics.";
const ogTitle = "B2B Lot Traceability | TooluBaay";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/traceability",
    url: "https://toolubaay.sn/traceability",
    name: "Product Traceability | TooluBaay",
    description: "Interactive B2B peanut paste lot traceability module.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn",
      name: "TooluBaay",
      description: "AgriTech and rural women peanut transformation cooperative in Senegal."
    },
    inLanguage: "en-US"
  }}
>
  <section class="relative overflow-hidden bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800 dark:bg-amber-950 dark:text-amber-200">
          Transparency & Quality
        </span>
        <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-4xl md:text-5xl">
          Trace Your Peanut Paste Lot
        </h1>
        <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
          Every pot of TooluBaay peanut paste comes with a QR code or lot number. Enter your code below to view detailed records of the cooperative, harvest conditions, and chemical safety checks (including aflatoxin reports).
        </p>
      </div>

      <!-- Interactive Lot Checker -->
      <div class="mx-auto mt-12 max-w-2xl">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-lg dark:border-neutral-800 dark:bg-neutral-950">
          <div class="space-y-4">
            <label for="lot-input" class="block text-sm font-semibold text-neutral-800 dark:text-neutral-200">
              Enter Lot Code
            </label>
            <div class="flex gap-3">
              <input
                type="text"
                id="lot-input"
                placeholder="e.g., TB-TBA-001 or TB-TVA-KAM-001"
                class="block w-full rounded-lg border border-neutral-300 bg-neutral-50 px-4 py-3 text-neutral-800 outline-none transition duration-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100 dark:focus:border-emerald-500"
              />
              <button
                id="trace-btn"
                class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-6 py-3 font-semibold text-white transition hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
              >
                Trace Lot
              </button>
            </div>
            <div>
              <p class="text-xs text-neutral-500 dark:text-neutral-400">
                Sample codes for testing: 
                <button class="sample-code-btn font-mono underline hover:text-emerald-600 dark:hover:text-emerald-500 mr-2">TB-TBA-001</button>, 
                <button class="sample-code-btn font-mono underline hover:text-emerald-600 dark:hover:text-emerald-500 mr-2">TB-TBA-003</button>, 
                <button class="sample-code-btn font-mono underline hover:text-emerald-600 dark:hover:text-emerald-500">TB-TBA-006</button>
              </p>
            </div>
          </div>

          <!-- Error Message Alert (Hidden by default) -->
          <div id="error-alert" class="mt-6 hidden rounded-lg bg-red-50 p-4 text-sm text-red-800 dark:bg-red-950/30 dark:text-red-300">
            <strong>Error:</strong> Lot code not found. Please try one of the sample codes listed above.
          </div>

          <!-- Results Details (Hidden by default) -->
          <div id="results-card" class="mt-8 hidden space-y-6 border-t border-neutral-200 pt-6 dark:border-neutral-800 animate-fadeIn">
            <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">
              Lot Origin Details: <span id="res-code" class="font-mono text-emerald-600 dark:text-emerald-500"></span>
            </h3>

            <!-- Grid Details -->
            <div class="grid gap-6 sm:grid-cols-2">
              <div class="space-y-4">
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">GIE Cooperative</h4>
                  <p id="res-gie" class="mt-1 font-bold text-neutral-800 dark:text-neutral-200"></p>
                </div>
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Location</h4>
                  <p id="res-location" class="mt-1 text-neutral-800 dark:text-neutral-200"></p>
                </div>
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Cooperative Leader</h4>
                  <p id="res-leader" class="mt-1 text-neutral-800 dark:text-neutral-200"></p>
                </div>
              </div>

              <div class="space-y-4">
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Harvest Period</h4>
                  <p id="res-harvest" class="mt-1 text-neutral-800 dark:text-neutral-200"></p>
                </div>
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Aflatoxin Analysis</h4>
                  <p id="res-aflatoxin" class="mt-1 font-semibold text-emerald-600 dark:text-emerald-500"></p>
                </div>
                <div>
                  <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Moisture Content</h4>
                  <p id="res-moisture" class="mt-1 text-neutral-800 dark:text-neutral-200"></p>
                </div>
              </div>
            </div>

            <!-- Certification Badges -->
            <div class="mt-4 rounded-xl bg-emerald-50 p-4 dark:bg-emerald-950/20 border border-emerald-100 dark:border-emerald-900/50">
              <div class="flex gap-3">
                <svg class="h-6 w-6 text-emerald-600 dark:text-emerald-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                </svg>
                <div>
                  <h4 class="text-sm font-bold text-emerald-800 dark:text-emerald-300">Certified Premium Quality</h4>
                  <p class="text-xs text-emerald-700 dark:text-emerald-400 mt-0.5">
                    This lot has successfully passed our centralized quality checkpoints. Hand-sorted, 100% natural, and verified aflatoxin-free.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Client-side Interactive Script -->
  <script>
    // Lot Database matching GIE data
    const lotDb: Record<string, { gie: string; location: string; leader: string; harvest: string; aflatoxin: string; moisture: string }> = {
      "TB-TBA-001": {
        gie: "GIE Kamben Transformation",
        location: "Dialacoto (Tambacounda, Senegal)",
        leader: "Manio Keita",
        harvest: "December 2025",
        aflatoxin: "Not Detected (< 1.5 ppb) - Compliant",
        moisture: "6.2%"
      },
      "TB-TVA-KAM-001": {
        gie: "GIE Kamben Transformation",
        location: "Dialacoto (Tambacounda, Senegal)",
        leader: "Manio Keita",
        harvest: "December 2025",
        aflatoxin: "Not Detected (< 1.5 ppb) - Compliant",
        moisture: "6.2%"
      },
      "TB-TBA-002": {
        gie: "GIE Fokaben",
        location: "Darsalam (Tambacounda, Senegal)",
        leader: "Koule Makalou",
        harvest: "November 2025",
        aflatoxin: "Certified Safe (< 2.0 ppb)",
        moisture: "6.5%"
      },
      "TB-TBA-003": {
        gie: "GIE GPF Leral",
        location: "Diagle-Sine (Tambacounda, Senegal)",
        leader: "Waatew Diouf",
        harvest: "December 2025",
        aflatoxin: "Not Detected (< 1.5 ppb) - Compliant",
        moisture: "6.1%"
      },
      "TB-TBA-004": {
        gie: "GIE Fandema Kaffo",
        location: "Bantantinty (Tambacounda, Senegal)",
        leader: "Fanta Toure",
        harvest: "November 2025",
        aflatoxin: "Certified Safe (< 2.0 ppb)",
        moisture: "6.4%"
      },
      "TB-TBA-005": {
        gie: "GIE And Jubbo",
        location: "Sinthiou Malem (Tambacounda, Senegal)",
        leader: "Mamadou Aliou Ba",
        harvest: "December 2025",
        aflatoxin: "Certified Safe (< 1.8 ppb)",
        moisture: "6.3%"
      },
      "TB-TBA-006": {
        gie: "GIE Takku Ligguey",
        location: "Keur Ousmane (Tambacounda, Senegal)",
        leader: "Ndeye Fatou Ndiaye",
        harvest: "December 2025",
        aflatoxin: "Not Detected (< 1.5 ppb) - Compliant",
        moisture: "6.0%"
      },
      "TB-TBA-007": {
        gie: "GIE Berete",
        location: "Darou Ndibélane (Tambacounda, Senegal)",
        leader: "Fatoumata Bintou Diallo",
        harvest: "November 2025",
        aflatoxin: "Certified Safe (< 2.0 ppb)",
        moisture: "6.6%"
      },
      "TB-TBA-008": {
        gie: "GIE Deggo",
        location: "Darou Ndibélane (Tambacounda, Senegal)",
        leader: "Alsane Diop",
        harvest: "December 2025",
        aflatoxin: "Certified Safe (< 1.9 ppb)",
        moisture: "6.3%"
      },
      "TB-TBA-009": {
        gie: "GIE 4R",
        location: "Sinthiou Malem (Tambacounda, Senegal)",
        leader: "Ndiémé Camara",
        harvest: "November 2025",
        aflatoxin: "Certified Safe (< 2.0 ppb)",
        moisture: "6.4%"
      },
      "TB-TBA-010": {
        gie: "GIE Alanso 2",
        location: "Bantantity (Tambacounda, Senegal)",
        leader: "Coumba Waly",
        harvest: "December 2025",
        aflatoxin: "Certified Safe (< 1.7 ppb)",
        moisture: "6.2%"
      }
    };

    // DOM references
    const lotInput = document.getElementById("lot-input") as HTMLInputElement | null;
    const traceBtn = document.getElementById("trace-btn");
    const errorAlert = document.getElementById("error-alert");
    const resultsCard = document.getElementById("results-card");
    const sampleBtns = document.querySelectorAll(".sample-code-btn");

    // Result field references
    const resCode = document.getElementById("res-code");
    const resGie = document.getElementById("res-gie");
    const resLocation = document.getElementById("res-location");
    const resLeader = document.getElementById("res-leader");
    const resHarvest = document.getElementById("res-harvest");
    const resAflatoxin = document.getElementById("res-aflatoxin");
    const resMoisture = document.getElementById("res-moisture");

    function executeTrace(code: string) {
      const cleanCode = code.trim().toUpperCase();
      if (!cleanCode) return;

      const record = lotDb[cleanCode];
      if (record) {
        // Show result
        if (errorAlert) errorAlert.classList.add("hidden");
        if (resultsCard) resultsCard.classList.remove("hidden");
        
        if (resCode) resCode.textContent = cleanCode;
        if (resGie) resGie.textContent = record.gie;
        if (resLocation) resLocation.textContent = record.location;
        if (resLeader) resLeader.textContent = record.leader;
        if (resHarvest) resHarvest.textContent = record.harvest;
        if (resAflatoxin) resAflatoxin.textContent = record.aflatoxin;
        if (resMoisture) resMoisture.textContent = record.moisture;
      } else {
        // Show error
        if (resultsCard) resultsCard.classList.add("hidden");
        if (errorAlert) errorAlert.classList.remove("hidden");
      }
    }

    // Trigger on button click
    traceBtn?.addEventListener("click", () => {
      if (lotInput) {
        executeTrace(lotInput.value);
      }
    });

    // Trigger on Enter key
    lotInput?.addEventListener("keypress", (e) => {
      if (e.key === "Enter") {
        executeTrace(lotInput.value);
      }
    });

    // Trigger on sample code click
    sampleBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const val = btn.textContent || "";
        if (lotInput) lotInput.value = val;
        executeTrace(val);
      });
    });
  </script>

  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
      animation: fadeIn 0.4s ease forwards;
    }
  </style>
</MainLayout>
