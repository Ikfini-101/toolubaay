---
const langProp = Astro.props?.lang;
const raw = (langProp ?? Astro.currentLocale ?? 'fr').toString().toLowerCase();
const lang = raw.startsWith('en') ? 'en' : 'fr';

const t = {
  fr: {
    badge: 'Partenariat',
    heading: 'En partenariat avec World Vision Sénégal',
    sub: 'Projet THRIVE — Transformer la Résilience des Ménages dans les Environnements Vulnérables',
    intro: "TooluBaay est fier de s'associer à World Vision Sénégal pour renforcer durablement la résilience économique des ménages vulnérables, à travers une approche fondée sur les principes de l'IMSD.",
    imsd: "L'IMSD — Développement des Systèmes de Marché Inclusifs — favorise des systèmes de marché plus inclusifs, performants et résilients, au service des communautés.",
    tag: 'World Vision Sénégal · VisionFund · TooluBaay',
    cards: [
      { k: '01', t: 'Un partenariat stratégique', d: "TooluBaay s'associe à World Vision Sénégal dans le cadre du projet THRIVE, pour renforcer durablement la résilience économique des ménages vulnérables grâce à l'approche IMSD." },
      { k: '02', t: 'Moyens de subsistance durables', d: "En améliorant l'accès à l'information, aux services et aux marchés, nous accompagnons les ménages vers des revenus renforcés, plus résilients face aux chocs économiques et climatiques." },
      { k: '03', t: 'Genre & inclusion sociale', d: "Une attention particulière est portée au leadership des femmes, des jeunes et des groupes marginalisés dans les chaînes de valeur, pour réduire les inégalités." },
      { k: '04', t: 'Communautés résilientes', d: "Ensemble, nous œuvrons pour des communautés plus résilientes, inclusives et prospères, capables de bâtir un avenir durable." },
    ],
  },
  en: {
    badge: 'Partnership',
    heading: 'In partnership with World Vision Senegal',
    sub: 'THRIVE Project — Transforming Households Resilience in Vulnerable Environments',
    intro: 'TooluBaay is proud to partner with World Vision Senegal to sustainably strengthen the economic resilience of vulnerable households, through an approach grounded in IMSD principles.',
    imsd: 'IMSD — Inclusive Market Systems Development — fosters more inclusive, effective and resilient market systems that serve communities.',
    tag: 'World Vision Senegal · VisionFund · TooluBaay',
    cards: [
      { k: '01', t: 'A strategic partnership', d: 'TooluBaay partners with World Vision Senegal on the THRIVE project, to sustainably strengthen the economic resilience of vulnerable households through the IMSD approach.' },
      { k: '02', t: 'Sustainable livelihoods', d: 'By improving access to information, services and markets, we help households build stronger incomes, more resilient to economic and climate shocks.' },
      { k: '03', t: 'Gender & social inclusion', d: 'Special focus is placed on the leadership of women, youth and marginalized groups in value chains, to reduce inequalities.' },
      { k: '04', t: 'Resilient communities', d: 'Together, we work toward more resilient, inclusive and prosperous communities, able to build a sustainable future.' },
    ],
  },
}[lang];
---

<section class="wvt">
  <div class="wvt__block" data-wvt>
    <div class="wvt__left">
      <span class="wvt__badge">{t.badge}</span>
      <div class="wvt__logo-wrap">
        <img class="wvt__logo" src="/partners/worldvision-thrive.png" alt="VisionFund · World Vision · THRIVE" />
      </div>
      <h2 class="wvt__title">{t.heading}</h2>
      <p class="wvt__sub">{t.sub}</p>
      <p class="wvt__intro">{t.intro}</p>
      <p class="wvt__imsd">{t.imsd}</p>
      <p class="wvt__tag">{t.tag}</p>
    </div>

    <div class="wvt__viewport" data-wvt-viewport>
      <div class="wvt__track" data-wvt-track>
        {t.cards.map((c) => (
          <article class="wvt__card" data-wvt-card>
            <span class="wvt__num">{c.k}</span>
            <h3 class="wvt__card-title">{c.t}</h3>
            <p class="wvt__card-text">{c.d}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .wvt {
    --wv-orange:#F26522;
    --wv-orange-ink:#A8430F;
    --wv-ink:#0c1f24;
    --wv-water-1: rgba(196,228,238,0.84);
    --wv-water-2: rgba(158,206,224,0.78);
    padding: clamp(2.5rem,6vw,5rem) 1rem;
  }

  .wvt__block {
    position: relative; max-width: 1140px; margin: 0 auto;
    display: grid; grid-template-columns: 46% 54%;
    height: 540px; border-radius: 24px; overflow: hidden;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
    border: 1px solid rgba(255,255,255,0.22);
    box-shadow: 0 30px 70px -30px rgba(0,0,0,.40);
  }

  /* GAUCHE : verre clair dense, contenu réparti du haut vers le bas */
  .wvt__left {
    position: relative; z-index: 2; padding: 1.5rem 1.75rem;
    display: flex; flex-direction: column; justify-content: center; gap: .6rem;
    background: linear-gradient(160deg, rgba(255,255,255,0.90), rgba(255,255,255,0.78));
    backdrop-filter: blur(20px) saturate(150%); -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-right: 1px solid rgba(255,255,255,0.5);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
  }
  .wvt__badge {
    align-self:flex-start; font-size:.65rem; letter-spacing:.14em; text-transform:uppercase; font-weight:700;
    color:var(--wv-orange-ink); border:1px solid var(--wv-orange-ink); border-radius:999px; padding:.25rem .75rem;
  }
  .wvt__logo-wrap {
    align-self:flex-start; max-width:280px; background:rgba(255,255,255,0.96);
    border-radius:12px; padding:.75rem 1rem; box-shadow:0 6px 18px -10px rgba(0,0,0,.3);
  }
  .wvt__logo { width:100%; height:auto; display:block; }
  .wvt__title { font-size: clamp(1rem,1.8vw,1.35rem); font-weight:800; color:var(--wv-ink) !important; margin:0; line-height:1.2; }
  .wvt__sub { color:#15333b !important; font-size:.85rem; line-height:1.35; margin:0; font-weight:600; }
  .wvt__intro { color:#13313a !important; font-size:.85rem; line-height:1.45; margin:0; }
  .wvt__imsd { color:#1c3f48 !important; font-size:.8rem; line-height:1.4; margin:0; padding-left:.75rem; border-left:3px solid var(--wv-orange); }
  .wvt__tag { margin:0; font-size:.65rem; letter-spacing:.06em; text-transform:uppercase; color:#3a5a62 !important; font-weight:700; }

  /* DROITE : défilement vertical très lent (inchangé) */
  .wvt__viewport {
    position: relative; overflow: hidden; height: 100%;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }
  .wvt__track { display: flex; flex-direction: column; gap: 1rem; padding: 1rem 1.25rem; will-change: transform; }
  .wvt__card {
    position: relative; width: 100%; box-sizing: border-box;
    padding: 1.3rem 1.5rem; border-radius: 16px;
    background: linear-gradient(135deg, var(--wv-water-1), var(--wv-water-2));
    backdrop-filter: blur(20px) saturate(170%); -webkit-backdrop-filter: blur(20px) saturate(170%);
    border: 1px solid rgba(255,255,255,0.5);
    border-left: 5px solid var(--wv-orange);
    box-shadow: 0 14px 34px -20px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,0.85);
    color: var(--wv-ink); overflow: hidden;
  }
  .wvt__card::before {
    content:''; position:absolute; inset:0; pointer-events:none;
    background: linear-gradient(125deg, rgba(255,255,255,0.35), rgba(255,255,255,0) 50%);
  }
  .wvt__card > * { position:relative; z-index:1; }
  .wvt__num { font-size:.82rem; font-weight:800; color:var(--wv-orange-ink); letter-spacing:.1em; }
  .wvt__card-title { font-size:1.05rem; font-weight:750; color:var(--wv-ink); margin:.35rem 0 .5rem; }
  .wvt__card-text { color:#0d2630; line-height:1.5; font-size:.9rem; margin:0; }

  @media (max-width: 768px) {
    .wvt__block { grid-template-columns: 1fr; height: auto; min-height: 0; }
    .wvt__left { border-right:none; border-bottom:1px solid rgba(255,255,255,0.5); justify-content:flex-start; }
    .wvt__viewport { height: 430px; }
  }
</style>

<script>
  // @ts-nocheck
  import gsap from 'gsap';

  function initWVT(root) {
    if (root.dataset.wvtReady) return;
    root.dataset.wvtReady = '1';

    const track = root.querySelector('[data-wvt-track]');
    if (!track) return;
    const cards = gsap.utils.toArray('[data-wvt-card]', track);
    const count = cards.length;
    cards.forEach((c) => track.appendChild(c.cloneNode(true)));

    // ⚙️ RÉGLAGES
    const REV = 32;     // secondes / set. PLUS GRAND = PLUS LENT.
    const DIR = -1;     // -1 = vers le haut. +1 = vers le bas.

    let tween = null;
    function build() {
      if (tween) tween.kill();
      gsap.set(track, { y: 0, force3D: true });
      const first = track.children[0];
      const firstClone = track.children[count];
      if (!first || !firstClone) return;
      const distance = Math.round(firstClone.offsetTop - first.offsetTop);
      const wrapY = gsap.utils.wrap(-distance, 0);
      tween = gsap.to(track, {
        y: DIR * distance,
        duration: REV,
        ease: 'none',
        repeat: -1,
        force3D: true,
        modifiers: { y: gsap.utils.unitize(wrapY) }
      });
    }

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    build();
    if (reduce && tween) tween.pause();
    root.addEventListener('mouseenter', () => tween && tween.pause());
    root.addEventListener('mouseleave', () => { if (tween && !reduce) tween.resume(); });
    window.addEventListener('resize', build);
  }

  function boot() { document.querySelectorAll('[data-wvt]').forEach(initWVT); }
  document.addEventListener('astro:page-load', boot);
  if (document.readyState !== 'loading') boot();
  else document.addEventListener('DOMContentLoaded', boot);
</script>
