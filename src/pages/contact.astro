---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/fr/ContactSection_fr.astro";
import { SITE } from "@data/constants";

const pageTitle: string = `Nous Contacter | ${SITE.title}`;
const metaDescription =
  "Vous avez des questions sur nos produits, nos GIE ou souhaitez discuter d'un partenariat B2B ? Contactez l'équipe TooluBaay pour échanger sur nos solutions AgriTech et notre pâte d'arachide premium.";
const ogTitle = "Nous Contacter | TooluBaay";
---

<MainLayout
  title={pageTitle}
  lang="fr"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.com/fr/contact",
    url: "https://toolubaay.com/fr/contact",
    name: "Nous Contacter | TooluBaay",
    description:
      "Vous avez des questions sur nos produits, nos GIE ou souhaitez discuter d'un partenariat B2B ? Contactez l'équipe TooluBaay pour échanger sur nos solutions AgriTech et notre pâte d'arachide premium.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.com/fr/",
      name: "TooluBaay",
      description:
        "TooluBaay propose de la pâte d'arachide premium et des solutions AgriTech pour renforcer les GIE de femmes rurales au Sénégal.",
    },
    inLanguage: "fr",
  }}
>
  <ContactSection />
</MainLayout>
