---
// Importing necessary components
import MainLayout from "@/layouts/MainLayout.astro";

import CardSmall from "@components/ui/cards/CardSmall.astro";
import CardWide from "@components/ui/cards/CardWide.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import { Image } from "astro:assets";
import peanutBg from "@images/decorations/peanut_without-bg.png";
// Importing necessary functions from Astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";

// Fetching all the product related content and sorting it by main.id
const product: CollectionEntry<"products">[] = (
  await getCollection("products", ({ id }) => {
    return id.startsWith("fr/");
  })
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id
);

// Define variables for page content
const title: string = "Pâte d'Arachide Premium";
const subTitle: string =
  "Découvrez notre gamme de pâte d'arachide 100% naturelle et de qualité supérieure. Fabriquée artisanalement par des coopératives de femmes rurales à Tambacounda, Sénégal. Garantie sans aflatoxine, riche en nutriments et à fort impact social.";

// Define variables for page content

const pageTitle = `Produits | ${SITE.title}`;
const metaDescription =
  "Découvrez nos formats de pâte d'arachide 100% naturelle et premium, fabriquée par des coopératives de femmes au Sénégal.";
const ogTitle = "Pâte d'Arachide Premium | TooluBaay";
---

<MainLayout
  title={pageTitle}
  lang="fr"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/products",
    url: "https://toolubaay.sn/products",
    name: "Pâte d'Arachide Premium | TooluBaay",
    description:
      "Découvrez nos formats de pâte d'arachide 100% naturelle et premium, fabriquée par des coopératives de femmes au Sénégal.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn",
      name: "TooluBaay",
      description:
        "TooluBaay structure la filière arachide au Sénégal, offrant aux coopératives de femmes rurales un accès au marché B2B.",
    },
    inLanguage: "fr",
  }}
>
  <!-- Glassmorphism Background & Giant Peanut -->
  <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
    <div class="absolute inset-0 bg-white/20 dark:bg-black/30 backdrop-blur-md"></div>
    <Image 
      src={peanutBg} 
      alt="" 
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] md:w-[90%] lg:w-[70%] max-w-none h-auto object-contain opacity-80 drop-shadow-2xl"
    />
  </div>

  <div
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full relative z-10"
  >
    <div class="mb-8 flex flex-col items-center text-center gap-4 sm:mb-12">
      <h1
        class="text-3xl font-bold tracking-tight text-balance text-neutral-800 md:text-5xl md:leading-tight dark:text-white drop-shadow-md"
      >
        {title}
      </h1>
      {
        subTitle && (
          <p class="max-w-3xl text-pretty text-neutral-700 md:block dark:text-neutral-200 text-lg drop-shadow-sm font-medium">
            {subTitle}
          </p>
        )
      }
    </div>
    {/* Displaying products in alternating styles. Alternative product gets different card styling. */}
    {/* Maps through all product entries and displays them with either CardSmall or CardWide based on their position. */}
    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} productLocale="fr" />;
          } else {
            return <CardWide product={product} productLocale="fr" />;
          }
        })
      }
    </section>
  </div>
  {/* Features statistics section */}
  <FeaturesStatsAlt
    title="Pourquoi choisir TooluBaay ?"
    subTitle="En choisissant nos produits, vous soutenez directement les femmes rurales sénégalaises. Nous garantissons une sélection rigoureuse des arachides brutes de qualité supérieure, un contrôle qualité strict (sans aflatoxine, sans additif) et une chaîne d'approvisionnement transparente et traçable."
    benefits={[
      "Pâte d'arachide 100% naturelle avec texture onctueuse et couleur ocre riche.",
      "Achat à prix garanti rémunérant équitablement les GIE de femmes rurales.",
      "Certification sans aflatoxine garantissant une sécurité alimentaire optimale.",
    ]}
  />
</MainLayout>
