---
import MainLayout from "@/layouts/MainLayout.astro";
import { SITE } from "@data/constants";

const pageTitle = `Technologie | ${SITE.title}`;
const metaDescription =
  "Découvrez la technologie TooluBaay : application agrométéo multilingue, QR code de traçabilité, mobile money et innovations numériques au service des femmes et des jeunes en milieu rural au Sénégal.";
const ogTitle = "Technologie & Innovation | TooluBaay";

const techPillars = [
  {
    icon: "📱",
    title: "Application Agrométéo Multilingue",
    description:
      "Application mobile disponible en wolof, pulaar et mandingue. Prévisions météo précises, conseils agronomiques adaptés et alertes risques climatiques pour les GIE partenaires.",
    features: [
      "Prévisions météo localisées (semis, récolte, irrigation)",
      "Alertes sécheresse et excès de pluie en temps réel",
      "Conseils variétés arachide & calendrier agricole",
      "Interface vocale adaptée aux femmes et jeunes peu alphabétisés",
    ],
    color: "emerald",
  },
  {
    icon: "🔍",
    title: "QR Code de Traçabilité",
    description:
      "Chaque pot de pâte d'arachide TooluBaay est équipé d'un QR code unique. Le consommateur peut scanner et accéder à l'historique complet du lot : GIE producteur, récolte, contrôles qualité.",
    features: [
      "Identification unique de chaque lot produit",
      "Lien direct vers fiche GIE de la coopérative",
      "Données qualité (taux aflatoxine, humidité)",
      "Renforce la confiance des acheteurs premium et export",
    ],
    color: "amber",
  },
  {
    icon: "💸",
    title: "Mobile Money & Paiements Digitaux",
    description:
      "Intégration du mobile money (Orange Money, Wave, Free Money) pour sécuriser les paiements entre TooluBaay et les GIE. Traçabilité financière totale, confiance renforcée.",
    features: [
      "Paiements GIE sécurisés en 48h via mobile money",
      "Suivi commandes et paiements en temps réel",
      "Réduction des risques liés au cash en zone rurale",
      "Historique transactions accessible aux GIE",
    ],
    color: "blue",
  },
  {
    icon: "🎓",
    title: "Module Formation Numérique",
    description:
      "Bibliothèque de vidéos courtes intégrées à l'application : bonnes pratiques d'hygiène, techniques de broyage, gestion de la qualité, maîtrise du packaging TooluBaay.",
    features: [
      "Vidéos courtes en langues locales (wolof, pulaar)",
      "Protocoles d'hygiène, de sécurité alimentaire et conformité HACCP",
      "Tutoriels utilisation équipements GIE",
      "Mise à jour continue selon retours terrain",
    ],
    color: "purple",
  },
];

const impactMetrics = [
  { value: "3", label: "Langues locales", sub: "Wolof, Pulaar, Mandingue" },
  { value: ">60%", label: "Pénétration mobile money", sub: "Au Sénégal" },
  { value: "7", label: "Étapes contrôle qualité", sub: "Traçées numériquement" },
  { value: "QR", label: "Code unique / lot", sub: "Sur chaque pot de pâte d'arachide" },
];
---

<MainLayout
  title={pageTitle}
  lang="fr"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/technology",
    url: "https://toolubaay.sn/technology",
    name: "Technologie & Innovation | TooluBaay",
    description: "Application agrométéo multilingue, QR code de traçabilité et mobile money au service des GIE de femmes et de jeunes en milieu rural.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn",
      name: "TooluBaay",
      description: "AgriTech et coopérative de transformation d'arachide par des femmes et des jeunes au Sénégal.",
    },
    inLanguage: "fr",
  }}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-neutral-900 via-emerald-950 to-neutral-900 py-20 lg:py-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 h-64 w-64 rounded-full bg-emerald-400 blur-3xl"></div>
      <div class="absolute bottom-10 right-10 h-64 w-64 rounded-full bg-amber-400 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-flex items-center gap-2 rounded-full bg-emerald-900/60 border border-emerald-700/50 px-4 py-1.5 text-sm font-medium text-emerald-300">
          🚀 Innovation AgriTech
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          La Technologie au Service
          <span class="text-emerald-400"> du Terrain</span>
        </h1>
        <p class="mt-6 text-lg text-neutral-300 leading-relaxed">
          TooluBaay développe des outils numériques pensés pour les réalités des femmes et des jeunes en milieu rural au Sénégal. Application mobile multilingue, traçabilité QR code et paiements mobile money — la technologie comme levier d'autonomisation.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/traceability"
            class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-6 py-3 font-semibold text-white transition hover:bg-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-neutral-900"
          >
            🔍 Tester la Traçabilité
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-xl border border-neutral-600 bg-neutral-800/60 px-6 py-3 font-semibold text-white transition hover:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:ring-offset-2 focus:ring-offset-neutral-900"
          >
            💬 Devenir Partenaire Tech
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Metrics -->
  <section class="bg-white dark:bg-neutral-950 py-12 border-b border-neutral-200 dark:border-neutral-800">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {impactMetrics.map((m) => (
          <div class="text-center">
            <p class="text-4xl font-black text-emerald-600 dark:text-emerald-400">{m.value}</p>
            <p class="mt-1 text-sm font-semibold text-neutral-800 dark:text-neutral-200">{m.label}</p>
            <p class="text-xs text-neutral-500 dark:text-neutral-400">{m.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology Pillars -->
  <section class="bg-neutral-50 dark:bg-neutral-900 py-16 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-100 sm:text-4xl">
          Les 4 Piliers Technologiques
        </h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">
          Un écosystème numérique intégré qui améliore chaque maillon de la chaîne de valeur arachide.
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2">
        {techPillars.map((pillar) => (
          <div class="rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm transition hover:shadow-md dark:border-neutral-800 dark:bg-neutral-950">
            <div class="flex items-start gap-4">
              <span class="text-4xl">{pillar.icon}</span>
              <div>
                <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">{pillar.title}</h3>
                <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">{pillar.description}</p>
              </div>
            </div>
            <ul class="mt-6 space-y-2">
              {pillar.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-neutral-700 dark:text-neutral-300">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- App Impact Section -->
  <section class="bg-white dark:bg-neutral-950 py-16 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
        <div>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800 dark:bg-amber-950 dark:text-amber-200">
            Avantage Compétitif Structurel
          </span>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-100 sm:text-4xl">
            L'Application TooluBaay : Un Multiplicateur de Rentabilité
          </h2>
          <p class="mt-4 text-neutral-600 dark:text-neutral-400 leading-relaxed">
            L'application agrométéo TooluBaay constitue un avantage compétitif structurel unique dans la filière arachide sénégalaise. Elle crée un cercle vertueux direct :
          </p>
          <div class="mt-6 space-y-4">
            {[
              { step: "1", title: "GIE Mieux Informés", desc: "Prévisions météo et conseils agronomiques précis réduisent les pertes pré-récolte." },
              { step: "2", title: "Meilleure Qualité de Pâte", desc: "Arachide mieux gérée = moins de rejets qualité au centre de conditionnement." },
              { step: "3", title: "Revenus GIE Stables", desc: "Moins de rejets = paiements garantis réguliers pour les femmes et jeunes des GIE." },
              { step: "4", title: "Approvisionnement Fiable", desc: "TooluBaay maintient ses engagements de qualité premium et export avec constance." },
            ].map((item) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 flex items-center justify-center h-8 w-8 rounded-full bg-emerald-600 text-white text-sm font-bold">
                  {item.step}
                </div>
                <div>
                  <h4 class="font-semibold text-neutral-800 dark:text-neutral-100">{item.title}</h4>
                  <p class="text-sm text-neutral-600 dark:text-neutral-400">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="mt-10 lg:mt-0">
          <div class="rounded-2xl bg-gradient-to-br from-emerald-600 to-emerald-800 p-8 text-white shadow-xl">
            <h3 class="text-xl font-bold mb-6">Impact Opérationnel Quantifié</h3>
            <div class="space-y-4">
              {[
                { label: "Réduction pertes post-récolte", value: "−15 à −25 %" },
                { label: "Lots rejetés pour qualité", value: "< 5 % (cible)" },
                { label: "Délai paiement GIE", value: "48h via mobile money" },
                { label: "GIE formés numériquement", value: "10 → 500 (Phase 5)" },
                { label: "Langues locales supportées", value: "3 (Wolof, Pulaar, Mandingue)" },
              ].map((item) => (
                <div class="flex items-center justify-between border-b border-emerald-700/50 pb-3">
                  <span class="text-sm text-emerald-100">{item.label}</span>
                  <span class="font-bold text-white">{item.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-emerald-700 dark:bg-emerald-800 py-16">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white">
        Vous avez un projet AgriTech pour l'Afrique ?
      </h2>
      <p class="mt-4 text-emerald-100 max-w-2xl mx-auto">
        TooluBaay est ouvert aux partenariats technologiques. Développeurs, bailleurs, incubateurs — contactez-nous pour co-construire des solutions adaptées au terrain.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={`https://wa.me/221770914639?text=${encodeURIComponent("Bonjour, je suis intéressé par un partenariat tech avec TooluBaay.")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 font-semibold text-emerald-700 transition hover:bg-emerald-50"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Contacter sur WhatsApp
        </a>
        <a
          href="mailto:info.toolubaay@gmail.com?subject=Partenariat Tech TooluBaay"
          class="inline-flex items-center gap-2 rounded-xl border border-white/30 bg-emerald-600/50 px-6 py-3 font-semibold text-white transition hover:bg-emerald-600"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          Nous Écrire par Email
        </a>
      </div>
    </div>
  </section>
</MainLayout>
