---
import MainLayout from "@/layouts/MainLayout.astro";
import { Image } from "astro:assets";
import womenCoop from "@images/women_cooperative.png";
import { SITE } from "@data/constants";

const pageTitle = `Notre Impact | ${SITE.title}`;
const metaDescription =
  "Découvrez comment TooluBaay autonomise les GIE de femmes et de jeunes en milieu rural au Sénégal, garantit des revenus équitables et pilote une transformation agricole durable.";
const ogTitle = "Impact & Durabilité | TooluBaay";

// GIE Cooperatives data
const cooperatives = [
  { code: "TB-TBA-001", name: "GIE Kamben Transformation", location: "Dialacoto", leader: "Manio Keita", role: "GIE Pilote Actif" },
  { code: "TB-TBA-002", name: "GIE Fokaben", location: "Darsalam", leader: "Koule Makalou", role: "GIE Partenaire" },
  { code: "TB-TBA-003", name: "GIE GPF LERAL", location: "Diagle-Sine", leader: "Waatew Diouf", role: "GIE Partenaire" },
  { code: "TB-TBA-004", name: "GIE Fandema Kaffo", location: "Bantantinty", leader: "Fanta Toure", role: "GIE Partenaire" },
  { code: "TB-TBA-005", name: "GIE And Jubbo", location: "Sinthiou Malem", leader: "Mamadou Aliou Ba", role: "GIE Partenaire" },
  { code: "TB-TBA-006", name: "GIE Takku Ligguey", location: "Keur Ousmane", leader: "Ndeye Fatou Ndiaye", role: "GIE Partenaire" },
  { code: "TB-TBA-007", name: "GIE Berete", location: "Darou Ndibélane", leader: "Fatoumata Bintou Diallo", role: "GIE Partenaire" },
  { code: "TB-TBA-008", name: "GIE Deggo", location: "Darou Ndibélane", leader: "Alsane Diop", role: "GIE Partenaire" },
  { code: "TB-TBA-009", name: "GIE 4R", location: "Sinthiou Malem", leader: "Ndiémé Camara", role: "GIE Partenaire" },
  { code: "TB-TBA-010", name: "GIE Alanso 2", location: "Bantantity", leader: "Coumba Waly", role: "GIE Partenaire" }
];

// SDG goals data
const sdgs = [
  {
    number: "1",
    title: "Pas de pauvreté",
    color: "#E5243B",
    bgClass: "bg-[#E5243B]/10 text-[#E5243B] dark:bg-[#E5243B]/20 dark:text-[#FF6B6B]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(229,36,59,0.3)]",
    description: "En achetant la pâte d'arachide brute à un prix d'achat garanti et équitable (bien supérieur au marché local), nous sécurisons et augmentons les revenus des familles en milieu rural."
  },
  {
    number: "5",
    title: "Égalité entre les sexes",
    color: "#EF402B",
    bgClass: "bg-[#EF402B]/10 text-[#EF402B] dark:bg-[#EF402B]/20 dark:text-[#FF8E7A]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(239,64,43,0.3)]",
    description: "Nous collaborons directement avec des groupements d'intérêt économique (GIE) gérés par des femmes et des jeunes, en leur apportant matériel et formation pour leur indépendance financière."
  },
  {
    number: "8",
    title: "Travail décent",
    color: "#A21942",
    bgClass: "bg-[#A21942]/10 text-[#A21942] dark:bg-[#A21942]/20 dark:text-[#FF6B8B]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(162,25,66,0.3)]",
    description: "Création de plus de 120 emplois directs pour les femmes et les jeunes en Phase 1, structurant et professionnalisant la filière sous des normes strictes de qualité."
  },
  {
    number: "13",
    title: "Mesures climatiques",
    color: "#3F7E44",
    bgClass: "bg-[#3F7E44]/10 text-[#3F7E44] dark:bg-[#3F7E44]/20 dark:text-[#81C784]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(63,126,68,0.3)]",
    description: "Mise à disposition de technologies d'assistance climatique (météo locale, calendriers culturaux) pour adapter les cultures aux dérèglements environnementaux."
  }
];

// Vision Sénégal 2050 data
const vision2050 = [
  {
    number: "1",
    title: "Souveraineté Alimentaire",
    color: "#008543",
    bgClass: "bg-[#008543]/10 text-[#008543] dark:bg-[#008543]/20 dark:text-[#34D399]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(0,133,67,0.25)]",
    description: "Réduction de la dépendance aux importations par une production locale accrue de pâte d'arachide de qualité supérieure."
  },
  {
    number: "2",
    title: "Industrialisation",
    color: "#D97706",
    bgClass: "bg-[#D97706]/10 text-[#D97706] dark:bg-[#D97706]/20 dark:text-[#FBBF24]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(217,119,6,0.25)]",
    description: "Modernisation des processus de transformation artisanale avec des équipements semi-industriels respectant les standards internationaux."
  },
  {
    number: "3",
    title: "Inclusion des Jeunes & Femmes",
    color: "#E31B23",
    bgClass: "bg-[#E31B23]/10 text-[#E31B23] dark:bg-[#E31B23]/20 dark:text-[#FCA5A5]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(227,27,35,0.25)]",
    description: "Intégration active et valorisation socio-économique des jeunes et des femmes en milieu rural à travers les GIE."
  },
  {
    number: "4",
    title: "Autonomisation Économique",
    color: "#008543",
    bgClass: "bg-[#008543]/10 text-[#008543] dark:bg-[#008543]/20 dark:text-[#34D399]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(0,133,67,0.25)]",
    description: "Garantie de revenus réguliers et durables pour les membres du réseau grâce à des prix d'achat équitables et contractuels."
  },
  {
    number: "5",
    title: "Agriculture Durable",
    color: "#D97706",
    bgClass: "bg-[#D97706]/10 text-[#D97706] dark:bg-[#D97706]/20 dark:text-[#FBBF24]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(217,119,6,0.25)]",
    description: "Déploiement de solutions AgriTech pour renforcer la résilience des cultures face aux défis agroclimatiques."
  },
  {
    number: "6",
    title: "Création de Valeur Locale",
    color: "#E31B23",
    bgClass: "bg-[#E31B23]/10 text-[#E31B23] dark:bg-[#E31B23]/20 dark:text-[#FCA5A5]",
    shadowClass: "hover:shadow-[0_10px_30px_-10px_rgba(227,27,35,0.25)]",
    description: "Valorisation de la matière première au Sénégal pour maximiser les retombées économiques directes dans les terroirs."
  }
];
---

<MainLayout
  title={pageTitle}
  lang="fr"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/impact",
    url: "https://toolubaay.sn/impact",
    name: "Notre Impact | TooluBaay",
    description: "Découvrez l'impact socio-économique et environnemental du modèle coopératif TooluBaay au Sénégal.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn",
      name: "TooluBaay",
      description: "AgriTech et GIE de transformation d'arachide par des femmes et jeunes au Sénégal."
    },
    inLanguage: "fr"
  }}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800 dark:bg-emerald-950 dark:text-emerald-200">
            Notre Mission & Impact
          </span>
          <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-4xl md:text-5xl">
            Autonomiser les Femmes & les Jeunes, <span class="text-emerald-600 dark:text-emerald-500">Transformer les Communautés</span>
          </h1>
          <p class="mt-6 text-lg text-neutral-600 dark:text-neutral-400">
            TooluBaay déploie un modèle hybride inclusif associant innovation AgriTech et agro-transformation locale. En soutenant un réseau structuré de GIE (Groupements d'Intérêt Économique) gérés par des femmes et des jeunes dans les différents pôles agricoles du pays, nous comblons le fossé entre les petits producteurs et les marchés pour une qualité premium.
          </p>
        </div>
        <div class="relative">
          <Image
            src={womenCoop}
            alt="Membres du GIE de femmes triant et transformant des arachides"
            class="w-full rounded-2xl object-cover shadow-xl dark:shadow-neutral-950"
          />
          <div class="absolute -bottom-6 -start-6 h-40 w-40 rounded-2xl bg-amber-500/10 -z-10"></div>
          <div class="absolute -top-6 -end-6 h-40 w-40 rounded-2xl bg-emerald-500/10 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Impact Stats -->
  <section class="bg-white py-12 dark:bg-neutral-950">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-12">
        <div class="text-center">
          <p class="text-4xl font-extrabold text-amber-500 md:text-5xl">120+</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Bénéficiaires Directs</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Femmes & jeunes en Phase 1</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-extrabold text-emerald-600 md:text-5xl">+20 GIE</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">GIE Actifs</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Réseau de GIE locaux</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-extrabold text-amber-500 md:text-4xl">Équitable</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Prix Garanti</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Payé directement au GIE</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-extrabold text-emerald-600 md:text-5xl">10%</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Réinvestissement</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Dédié aux formations professionnelles</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SDG Section -->
  <section class="bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Alignement avec les Objectifs de Développement Durable</h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">Notre modèle d'impact est structuré autour des priorités des Nations Unies pour dynamiser durablement l'économie rurale sénégalaise.</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {sdgs.map((sdg) => (
          <div 
            class={`group relative flex flex-col overflow-hidden rounded-2xl bg-white/80 p-6 backdrop-blur-md border border-neutral-200/50 dark:bg-neutral-900/60 dark:border-neutral-800/50 transition-all duration-300 hover:-translate-y-1 hover:bg-white dark:hover:bg-neutral-900 ${sdg.shadowClass}`}
            style={{ borderLeft: `4px solid ${sdg.color}` }}
          >
            {/* Watermark Number */}
            <span 
              class="absolute right-4 top-2 select-none text-7xl font-black opacity-[0.08] dark:opacity-[0.12] transition-transform duration-500 group-hover:scale-110"
              style={{ color: sdg.color }}
            >
              {sdg.number}
            </span>

            {/* Icon and Badge */}
            <div class="flex items-center gap-4">
              <span class={`flex h-12 w-12 items-center justify-center rounded-xl ${sdg.bgClass} transition-transform duration-300 group-hover:scale-110`}>
                {sdg.number === "1" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 11l9-9 9 9" />
                    <path d="M9 21v-4a2 2 0 0 1 4 0v4" />
                    <circle cx="12" cy="11" r="2" />
                    <path d="M7 21v-2a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v2" />
                  </svg>
                )}
                {sdg.number === "5" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="5" />
                    <path d="M12 15v6M9 18h6" />
                    <path d="M15.5 6.5L20 2M20 2h-4.5M20 2v4.5" />
                  </svg>
                )}
                {sdg.number === "8" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 20h18M3 20V4" />
                    <path d="M3 16l5-5 4 3 8-8" />
                    <path d="M16 6h4v4" />
                  </svg>
                )}
                {sdg.number === "13" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
                    <path d="M2 12h20" />
                    <path d="M12 12c2-2 4-2 5-1a6 6 0 0 1-1 5c-1 1-3 0-4-4z" />
                  </svg>
                )}
              </span>
              <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${sdg.bgClass}`}>
                ODD {sdg.number}
              </span>
            </div>

            {/* Title */}
            <h3 class="mt-5 font-extrabold text-neutral-800 dark:text-neutral-200 text-lg transition-colors group-hover:text-emerald-600 dark:group-hover:text-emerald-400">
              {sdg.title}
            </h3>

            {/* Description */}
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed flex-grow">
              {sdg.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Vision Sénégal 2050 Section -->
  <section class="bg-white py-16 dark:bg-neutral-950 lg:py-24 border-t border-neutral-200/20">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Alignement avec la Vision Sénégal 2050</h2>
        
        {/* Senegal flag divider */}
        <div class="mx-auto mt-4 h-1 w-24 bg-gradient-to-r from-emerald-600 via-amber-400 to-red-600 rounded-full"></div>
        
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">TooluBaay s'inscrit pleinement dans les orientations stratégiques nationales du Sénégal pour l'émergence d'une économie rurale forte, inclusive et souveraine.</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {vision2050.map((item) => (
          <div class={`group relative flex flex-col overflow-hidden rounded-2xl bg-white/80 p-6 backdrop-blur-md border border-neutral-200/50 dark:bg-neutral-900/60 dark:border-neutral-800/50 transition-all duration-300 hover:-translate-y-1 hover:bg-white dark:hover:bg-neutral-900 ${item.shadowClass}`}>
            
            {/* Senegal Flag top accent line */}
            <div class="absolute top-0 left-0 h-[3px] w-full bg-gradient-to-r from-emerald-600 via-amber-400 to-red-600"></div>

            {/* Icon and Badge */}
            <div class="flex items-center justify-between">
              <span class={`flex h-12 w-12 items-center justify-center rounded-xl ${item.bgClass} transition-transform duration-300 group-hover:scale-110`}>
                {item.number === "1" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2v20M12 6c3 0 5-2 5-2s-1 3-5 3M12 10c3 0 5-2 5-2s-1 3-5 3M12 14c3 0 5-2 5-2s-1 3-5 3" />
                    <path d="M12 6c-3 0-5-2-5-2s1 3 5 3M12 10c-3 0-5-2-5-2s1 3 5 3M12 14c-3 0-5-2-5-2s1 3 5 3" />
                  </svg>
                )}
                {item.number === "2" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                  </svg>
                )}
                {item.number === "3" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                )}
                {item.number === "4" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 7L13.5 15.5L8.5 10.5L2 17" />
                    <path d="M16 7H22V13" />
                    <path d="M2 22h20" stroke-dasharray="2 2" />
                  </svg>
                )}
                {item.number === "5" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 20h10" />
                    <path d="M10 20V14" />
                    <path d="M14 20V12" />
                    <path d="M12 12c4-4 4-9 4-9s-5 0-9 4c-3 3-3 8-3 8s4 0 8-3z" />
                  </svg>
                )}
                {item.number === "6" && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
                    <path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" />
                  </svg>
                )}
              </span>
              <span class={`flex h-8 w-8 items-center justify-center rounded-full text-sm font-extrabold ${item.bgClass}`}>
                {item.number}
              </span>
            </div>

            {/* Title */}
            <h3 class="mt-5 font-extrabold text-neutral-800 dark:text-neutral-200 text-lg transition-colors group-hover:text-emerald-600 dark:group-hover:text-emerald-400">
              {item.title}
            </h3>

            {/* Description */}
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed flex-grow">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GIE Partners Section -->
  <section class="bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24 border-t border-neutral-200/20">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Notre Réseau de GIE de Femmes et de Jeunes</h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">
          Nous collaborons avec un réseau de GIE partenaires dans les différents pôles agricoles du pays. Nous uniformisons le matériel de production et offrons des formations rigoureuses pour garantir des normes d'hygiène élevées, une sécurité optimale et la conformité aux normes HACCP.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cooperatives.map((coop) => (
          <div class="group flex flex-col justify-between rounded-xl border border-neutral-200 bg-white p-6 transition-all duration-300 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-950">
            <div>
              <div class="flex items-center justify-between">
                <span class="text-xs font-mono font-bold text-neutral-500 dark:text-neutral-400">{coop.code}</span>
                <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-950 dark:text-amber-200">
                  {coop.role}
                </span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-neutral-800 group-hover:text-emerald-600 dark:text-neutral-200 dark:group-hover:text-emerald-500 transition-colors">
                {coop.name}
              </h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
                <span class="font-semibold text-neutral-700 dark:text-neutral-300">Localisation:</span> {coop.location}
              </p>
              <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                <span class="font-semibold text-neutral-700 dark:text-neutral-300">Responsable:</span> {coop.leader}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
