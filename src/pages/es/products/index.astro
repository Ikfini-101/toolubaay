---
// Importing necessary components
import MainLayout from "@/layouts/MainLayout.astro";

import CardSmall from "@components/ui/cards/CardSmall.astro";
import CardWide from "@components/ui/cards/CardWide.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import FloatingPeanuts from "@components/ui/decorations/FloatingPeanuts.astro";
// Importing necessary functions from Astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";

// Fetching Spanish product content
const product: CollectionEntry<"products">[] = (
  await getCollection("products", ({ id }) => {
    return id.startsWith("es/");
  })
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id
);

// Define variables for page content
const title: string = "Pasta de Maní Premium";
const subTitle: string =
  "Explore nuestra gama de pasta de maní 100% natural y premium. Elaborada artesanalmente por cooperativas de mujeres locales en Tambacounda, Senegal. Garantizada libre de aflatoxinas, rica en nutrición e impacto social.";



const pageTitle: string = `Productos | ${SITE.title}`;
const metaDescription =
  "Descubra nuestros formatos de pasta de maní 100% natural y premium, elaborados por cooperativas de mujeres senegalesas.";
const ogTitle = "Pasta de Maní Premium | TooluBaay";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  lang="es"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/es/products",
    url: "https://toolubaay.sn/es/products",
    name: "Pasta de Maní Premium | TooluBaay",
    description:
      "Descubra nuestros formatos de pasta de maní 100% natural y premium, elaborados por cooperativas de mujeres senegalesas.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn/es",
      name: "TooluBaay",
      description:
        "TooluBaay estructura la cadena de valor del maní en Senegal, proporcionando herramientas digitales y acceso a mercados B2B.",
    },
    inLanguage: "es",
  }}
>
  <div class="relative w-full overflow-hidden">
    <FloatingPeanuts />
    <div
      class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full relative z-10"
    >
    <div class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12">
      <div class="flex items-center gap-12">
        <h1
          class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
        >
          {title}
        </h1>
        {
          subTitle && (
            <p class="hidden max-w-(--breakpoint-sm) text-pretty text-neutral-600 md:block dark:text-neutral-400">
              {subTitle}
            </p>
          )
        }
    </div>
    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} productLocale="es" />;
          } else {
            return <CardWide product={product} productLocale="es" />;
          }
        })
      }
    </section>
    </div>
  </div>
  {/* Features statistics section */}
  <FeaturesStatsAlt
    title="¿Por qué elegir TooluBaay?"
    subTitle="Al elegir nuestros productos, usted apoya directamente a las mujeres rurales senegalesas. Garantizamos la selección de maní crudo de alta calidad, un estricto control de calidad (cero aflatoxinas, cero aditivos) y una cadena de suministro transparente y trazable."
    benefits={[
      "Pasta de maní 100% natural con textura premium y color ocre.",
      "Compra a precios justos que empodera directamente a las cooperativas GIE.",
      "Certificación libre de aflatoxinas para cumplir con los más altos estándares de seguridad alimentaria.",
    ]}
  />
</MainLayout>
