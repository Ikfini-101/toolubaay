---
import MainLayout from "@/layouts/MainLayout.astro";
import { Image } from "astro:assets";
import womenCoop from "@images/women_cooperative.png";
import { SITE } from "@data/constants";

const pageTitle = `Notre Impact | ${SITE.title}`;
const metaDescription =
  "Découvrez comment TooluBaay autonomise les coopératives de femmes rurales au Sénégal, garantit des revenus équitables et pilote une transformation agricole durable.";
const ogTitle = "Impact & Durabilité | TooluBaay";

// GIE Cooperatives data
const cooperatives = [
  { code: "TB-TBA-001", name: "GIE Kamben Transformation", location: "Dialacoto", leader: "Manio Keita", role: "GIE Pilote Actif" },
  { code: "TB-TBA-002", name: "GIE Fokaben", location: "Darsalam", leader: "Koule Makalou", role: "GIE Partenaire" },
  { code: "TB-TBA-003", name: "GIE GPF LERAL", location: "Diagle-Sine", leader: "Waatew Diouf", role: "GIE Partenaire" },
  { code: "TB-TBA-004", name: "GIE Fandema Kaffo", location: "Bantantinty", leader: "Fanta Toure", role: "GIE Partenaire" },
  { code: "TB-TBA-005", name: "GIE And Jubbo", location: "Sinthiou Malem", leader: "Mamadou Aliou Ba", role: "GIE Partenaire" },
  { code: "TB-TBA-006", name: "GIE Takku Ligguey", location: "Keur Ousmane", leader: "Ndeye Fatou Ndiaye", role: "GIE Partenaire" },
  { code: "TB-TBA-007", name: "GIE Berete", location: "Darou Ndibélane", leader: "Fatoumata Bintou Diallo", role: "GIE Partenaire" },
  { code: "TB-TBA-008", name: "GIE Deggo", location: "Darou Ndibélane", leader: "Alsane Diop", role: "GIE Partenaire" },
  { code: "TB-TBA-009", name: "GIE 4R", location: "Sinthiou Malem", leader: "Ndiémé Camara", role: "GIE Partenaire" },
  { code: "TB-TBA-010", name: "GIE Alanso 2", location: "Bantantity", leader: "Coumba Waly", role: "GIE Partenaire" }
];

// SDG goals data
const sdgs = [
  {
    number: "1",
    title: "Pas de pauvreté",
    description: "En achetant la pâte d'arachide brute à un prix garanti de 800 FCFA/kg (bien supérieur au marché local), nous sécurisons et augmentons les revenus des familles rurales."
  },
  {
    number: "5",
    title: "Égalité entre les sexes",
    description: "Nous collaborons directement avec des groupements d'intérêt économique (GIE) gérés par des femmes, en leur apportant matériel et formation pour leur indépendance financière."
  },
  {
    number: "8",
    title: "Travail décent",
    description: "Création de plus de 120 emplois directs en Phase 1, structurant et professionnalisant la filière artisanale sous des normes d'hygiène et de qualité strictes."
  },
  {
    number: "13",
    title: "Mesures climatiques",
    description: "Mise à disposition de technologies d'assistance climatique (météo locale, calendriers culturaux) pour adapter les cultures aux dérèglements environnementaux."
  }
];
---

<MainLayout
  title={pageTitle}
  lang="fr"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://toolubaay.sn/impact",
    url: "https://toolubaay.sn/impact",
    name: "Notre Impact | TooluBaay",
    description: "Découvrez l'impact socio-économique et environnemental du modèle coopératif TooluBaay au Sénégal.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://toolubaay.sn",
      name: "TooluBaay",
      description: "AgriTech et coopérative de transformation d'arachide par des femmes rurales au Sénégal."
    },
    inLanguage: "fr"
  }}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800 dark:bg-emerald-950 dark:text-emerald-200">
            Notre Mission & Impact
          </span>
          <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-4xl md:text-5xl">
            Autonomiser les Femmes, <span class="text-emerald-600 dark:text-emerald-500">Transformer les Communautés</span>
          </h1>
          <p class="mt-6 text-lg text-neutral-600 dark:text-neutral-400">
            TooluBaay déploie un modèle hybride inclusif associant innovation AgriTech et agro-transformation locale. En soutenant des GIE (Groupements d'Intérêt Économique) gérés par des femmes rurales dans les régions de Tambacounda et Kaffrine, nous comblons le fossé entre les petits producteurs et les marchés B2B.
          </p>
        </div>
        <div class="relative">
          <Image
            src={womenCoop}
            alt="Membres de la coopérative de femmes triant et transformant des arachides"
            class="w-full rounded-2xl object-cover shadow-xl dark:shadow-neutral-950"
          />
          <div class="absolute -bottom-6 -start-6 h-40 w-40 rounded-2xl bg-amber-500/10 -z-10"></div>
          <div class="absolute -top-6 -end-6 h-40 w-40 rounded-2xl bg-emerald-500/10 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Impact Stats -->
  <section class="bg-white py-12 dark:bg-neutral-950">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-12">
        <div class="text-center">
          <p class="text-4xl font-extrabold text-amber-500 md:text-5xl">120+</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Bénéficiaires Directes</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Femmes & jeunes en Phase 1</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-extrabold text-emerald-600 md:text-5xl">+20 GIE</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Coopératives Actives</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Réseau de GIE locaux</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-extrabold text-amber-500 md:text-4xl">Équitable</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Prix Garanti</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Payé directement aux femmes</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-extrabold text-emerald-600 md:text-5xl">10%</p>
          <h2 class="mt-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200 uppercase tracking-wider">Réinvestissement</h2>
          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Dédié aux formations professionnelles</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SDG Section -->
  <section class="bg-neutral-50 py-16 dark:bg-neutral-900 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Alignement avec les Objectifs de Développement Durable</h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">Notre modèle d'impact est structuré autour des priorités des Nations Unies pour dynamiser durablement l'économie rurale sénégalaise.</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {sdgs.map((sdg) => (
          <div class="flex flex-col rounded-xl bg-white p-6 shadow-sm dark:bg-neutral-950 dark:border-neutral-800 border border-neutral-200">
            <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-100 text-lg font-bold text-emerald-800 dark:bg-emerald-950 dark:text-emerald-200">
              {sdg.number}
            </span>
            <h3 class="mt-5 font-bold text-neutral-800 dark:text-neutral-200 text-lg">ODD {sdg.number}: {sdg.title}</h3>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed flex-grow">
              {sdg.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GIE Partners Section -->
  <section class="bg-white py-16 dark:bg-neutral-950 lg:py-24">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200">Notre Réseau de GIE de Femmes Rurales</h2>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">
          En Phase 1, nous collaborons avec 10 coopératives locales dans la région de Tambacounda. Nous uniformisons le matériel de production et offrons un kit de démarrage pour garantir des normes d'hygiène et de sécurité élevées.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cooperatives.map((coop) => (
          <div class="group flex flex-col justify-between rounded-xl border border-neutral-200 bg-neutral-50 p-6 transition-all duration-300 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900">
            <div>
              <div class="flex items-center justify-between">
                <span class="text-xs font-mono font-bold text-neutral-500 dark:text-neutral-400">{coop.code}</span>
                <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-950 dark:text-amber-200">
                  {coop.role}
                </span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-neutral-800 group-hover:text-emerald-600 dark:text-neutral-200 dark:group-hover:text-emerald-500 transition-colors">
                {coop.name}
              </h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
                <span class="font-semibold text-neutral-700 dark:text-neutral-300">Localisation:</span> {coop.location}
              </p>
              <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                <span class="font-semibold text-neutral-700 dark:text-neutral-300">Responsable:</span> {coop.leader}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
